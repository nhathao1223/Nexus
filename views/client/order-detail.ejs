<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> - NEXUS</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <%- include('partials/header') %>
  
  <div class="container mt-4">
    <div class="row">
      <div class="col-12">
        <div class="alert alert-success" role="alert">
          <i class="bi bi-check-circle me-2"></i>
          <strong>Đặt hàng thành công!</strong> Cảm ơn bạn đã mua hàng tại cửa hàng của chúng tôi.
        </div>
      </div>
    </div>

    <div class="row">
      <div class="col-md-8">
        <div class="card">
          <div class="card-header">
            <h5 class="mb-0">Chi tiết đơn hàng #<%= order._id.toString().slice(-8).toUpperCase() %></h5>
          </div>
          <div class="card-body">
            <div class="row mb-3">
              <div class="col-md-6">
                <strong>Ngày đặt:</strong> <%= order.createdAt.toLocaleDateString('vi-VN') %>
              </div>
              <div class="col-md-6">
                <strong>Trạng thái:</strong> 
                <% if (order.status === 'pending') { %>
                  <span class="badge bg-warning">Chờ xác nhận</span>
                <% } else if (order.status === 'confirmed') { %>
                  <span class="badge bg-info">Đã xác nhận</span>
                <% } else if (order.status === 'shipping') { %>
                  <span class="badge bg-primary">Đang giao hàng</span>
                <% } else if (order.status === 'delivered') { %>
                  <span class="badge bg-success">Đã giao hàng</span>
                <% } else if (order.status === 'cancelled') { %>
                  <span class="badge bg-danger">Đã hủy</span>
                <% } %>
              </div>
            </div>

            <h6 class="mb-3">Sản phẩm đã đặt:</h6>
            <div class="table-responsive">
              <table class="table">
                <thead>
                  <tr>
                    <th>Sản phẩm</th>
                    <th>Giá</th>
                    <th>Số lượng</th>
                    <th>Tổng</th>
                  </tr>
                </thead>
                <tbody>
                  <% order.items.forEach(item => { %>
                    <tr>
                      <td>
                        <div class="d-flex align-items-center">
                          <% if (item.product && item.product.thumbnail) { %>
                            <img src="<%= publicUrl(item.product.thumbnail) %>" width="50" class="me-3 product-image">
                          <% } %>
                          <span><%= item.product ? item.product.title : 'Sản phẩm không tồn tại' %></span>
                        </div>
                      </td>
                      <td><%= item.price.toLocaleString('vi-VN') %>₫</td>
                      <td><%= item.quantity %></td>
                      <td><%= (item.price * item.quantity).toLocaleString('vi-VN') %>₫</td>
                    </tr>
                  <% }) %>
                </tbody>
              </table>
            </div>
          </div>
        </div>
      </div>

      <div class="col-md-4">
        <div class="card mb-4">
          <div class="card-header">
            <h6 class="mb-0">Thông tin giao hàng</h6>
          </div>
          <div class="card-body">
            <p class="mb-1"><strong><%= order.shippingAddress.fullName %></strong></p>
            <p class="mb-1"><i class="bi bi-telephone me-2"></i><%= order.shippingAddress.phone %></p>
            <p class="mb-1"><i class="bi bi-geo-alt me-2"></i><%= order.shippingAddress.address %></p>
            <p class="mb-1">
              <% if (order.shippingAddress.wardName) { %>
                <%= order.shippingAddress.wardName %>, 
              <% } %>
              <% if (order.shippingAddress.districtName) { %>
                <%= order.shippingAddress.districtName %>, 
              <% } %>
              <% if (order.shippingAddress.provinceName) { %>
                <%= order.shippingAddress.provinceName %>
              <% } %>
            </p>
          </div>
        </div>

        <div class="card mb-4">
          <div class="card-header">
            <h6 class="mb-0">Phương thức thanh toán</h6>
          </div>
          <div class="card-body">
            <% if (order.paymentMethod === 'cod') { %>
              <i class="bi bi-cash me-2"></i>Thanh toán khi nhận hàng
            <% } else if (order.paymentMethod === 'bank') { %>
              <i class="bi bi-credit-card me-2"></i>Chuyển khoản ngân hàng
            <% } else if (order.paymentMethod === 'momo') { %>
              <i class="bi bi-phone me-2"></i>Ví MoMo
              <% if (order.paymentStatus) { %>
                <br>
                <small class="text-muted">
                  Trạng thái: 
                  <% if (order.paymentStatus === 'paid') { %>
                    <span class="badge bg-success">Đã thanh toán</span>
                  <% } else if (order.paymentStatus === 'failed') { %>
                    <span class="badge bg-danger">Thanh toán thất bại</span>
                  <% } else { %>
                    <span class="badge bg-warning">Chờ thanh toán</span>
                  <% } %>
                </small>
                <% if (order.momoTransactionId) { %>
                  <br><small class="text-muted">Mã giao dịch: <%= order.momoTransactionId %></small>
                <% } %>
              <% } %>
            <% } %>
          </div>
        </div>

        <div class="card">
          <div class="card-header">
            <h6 class="mb-0">Tổng đơn hàng</h6>
          </div>
          <div class="card-body">
            <div class="d-flex justify-content-between mb-2">
              <span>Tạm tính:</span>
              <span><%= order.totalAmount.toLocaleString('vi-VN') %>₫</span>
            </div>
            <div class="d-flex justify-content-between mb-2">
              <span>Phí vận chuyển:</span>
              <span>Miễn phí</span>
            </div>
            <hr>
            <div class="d-flex justify-content-between">
              <strong>Tổng cộng:</strong>
              <strong class="text-danger"><%= order.totalAmount.toLocaleString('vi-VN') %>₫</strong>
            </div>
          </div>
        </div>
      </div>
    </div>

    <div class="row mt-4">
      <div class="col-12 text-center">
        <a href="/products" class="btn btn-primary me-2">Tiếp tục mua sắm</a>
        <a href="/" class="btn btn-outline-secondary">Về trang chủ</a>
      </div>
    </div>
  </div>

  <%- include('partials/footer') %>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
  <script src="/js/main.js"></script>
</body>
</html>