<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> - NEXUS</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
  <link rel="stylesheet" href="/css/style.css">
  <link rel="stylesheet" href="/css/products.css">
</head>
<body>
  <%- include('partials/header') %>
  
  <% if (success_msg && success_msg.length > 0) { %>
    <div class="container mt-3">
      <div class="alert alert-success alert-dismissible fade show" role="alert">
        <%= success_msg %>
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
      </div>
    </div>
  <% } %>
  
  <% if (error_msg && error_msg.length > 0) { %>
    <div class="container mt-3">
      <div class="alert alert-danger alert-dismissible fade show" role="alert">
        <%= error_msg %>
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
      </div>
    </div>
  <% } %>

  <div class="hero-section">
    <div class="container">
      <div class="row align-items-center">
        <div class="col-lg-6 text-white">
          <h1 class="hero-title mb-3">
            Mua sắm thông minh<br>
            <span class="highlight">Giá tốt mỗi ngày</span>
          </h1>
          <p class="hero-subtitle mb-4">
            Hàng ngàn sản phẩm chính hãng - Giá cạnh tranh - Giao hàng nhanh chóng
          </p>
          <div class="d-flex gap-3 flex-wrap">
            <a href="#products" class="btn btn-light btn-lg px-4">
              <i class="bi bi-grid me-2"></i>Khám phá ngay
            </a>
            <a href="?sort=price-asc" class="btn btn-outline-light btn-lg px-4">
              <i class="bi bi-lightning-fill me-2"></i>Ưu đãi hot
            </a>
          </div>
          
          <div class="hero-features mt-4">
            <div class="row g-3">
              <div class="col-6 col-md-3">
                <div class="feature-item">
                  <i class="bi bi-shield-check fs-4"></i>
                  <span class="ms-2">Chính hãng 100%</span>
                </div>
              </div>
              <div class="col-6 col-md-3">
                <div class="feature-item">
                  <i class="bi bi-truck fs-4"></i>
                  <span class="ms-2">Giao hàng nhanh</span>
                </div>
              </div>
              <div class="col-6 col-md-3">
                <div class="feature-item">
                  <i class="bi bi-arrow-repeat fs-4"></i>
                  <span class="ms-2">Đổi trả 7 ngày</span>
                </div>
              </div>
              <div class="col-6 col-md-3">
                <div class="feature-item">
                  <i class="bi bi-headset fs-4"></i>
                  <span class="ms-2">Hỗ trợ 24/7</span>
                </div>
              </div>
            </div>
          </div>
        </div>
        
        <div class="col-lg-6 d-none d-lg-block">
          <div class="hero-image">
            <img src="https://images.unsplash.com/photo-1607082348824-0a96f2a4b9da?w=600&h=400&fit=crop" 
                 alt="Shopping" 
                 class="img-fluid rounded-3 shadow-lg"
                 style="max-height: 400px; object-fit: cover; width: 100%;">
          </div>
        </div>
      </div>
    </div>
  </div>

  <div class="container mt-4" id="products">
    <h2 class="mb-4">
      <i class="bi bi-grid-3x3-gap me-2"></i>Tất cả sản phẩm
    </h2>
    
    <div class="row">
      <div class="col-lg-12 mb-4">
        <!-- Filter Bar -->
        <div class="filter-bar bg-white p-3 rounded shadow-sm border">
          <form method="GET" class="row g-3 align-items-end">
            <!-- Brand Filter -->
            <div class="col-md-3">
              <label class="form-label fw-semibold text-muted small">Hãng:</label>
              <select class="form-select form-select-sm" name="brand">
                <option value="">Tất cả hãng</option>
                <option value="apple" <%= query.brand === 'apple' ? 'selected' : '' %>>Apple</option>
                <option value="samsung" <%= query.brand === 'samsung' ? 'selected' : '' %>>Samsung</option>
                <option value="xiaomi" <%= query.brand === 'xiaomi' ? 'selected' : '' %>>Xiaomi</option>
                <option value="oppo" <%= query.brand === 'oppo' ? 'selected' : '' %>>OPPO</option>
                <option value="vivo" <%= query.brand === 'vivo' ? 'selected' : '' %>>Vivo</option>
              </select>
            </div>

            <!-- Price Filter -->
            <div class="col-md-3">
              <label class="form-label fw-semibold text-muted small">Giá:</label>
              <select class="form-select form-select-sm" name="priceRange">
                <option value="">Tất cả mức giá</option>
                <option value="0-5" <%= query.priceRange === '0-5' ? 'selected' : '' %>>Dưới 5 triệu</option>
                <option value="5-10" <%= query.priceRange === '5-10' ? 'selected' : '' %>>5 - 10 triệu</option>
                <option value="10-20" <%= query.priceRange === '10-20' ? 'selected' : '' %>>10 - 20 triệu</option>
                <option value="20+" <%= query.priceRange === '20+' ? 'selected' : '' %>>Trên 20 triệu</option>
              </select>
            </div>

            <!-- Category Filter -->
            <div class="col-md-3">
              <label class="form-label fw-semibold text-muted small">Danh mục:</label>
              <select class="form-select form-select-sm" name="category">
                <option value="">Tất cả danh mục</option>
                <% categories.forEach(cat => { %>
                  <option value="<%= cat._id %>" <%= query.category === cat._id.toString() ? 'selected' : '' %>>
                    <%= cat.name %>
                  </option>
                <% }) %>
              </select>
            </div>

            <!-- Sort -->
            <div class="col-md-2">
              <label class="form-label fw-semibold text-muted small">Sắp xếp:</label>
              <select class="form-select form-select-sm" name="sort">
                <option value="">Mới nhất</option>
                <option value="price-asc" <%= query.sort === 'price-asc' ? 'selected' : '' %>>Giá: Thấp → Cao</option>
                <option value="price-desc" <%= query.sort === 'price-desc' ? 'selected' : '' %>>Giá: Cao → Thấp</option>
                <option value="name-asc" <%= query.sort === 'name-asc' ? 'selected' : '' %>>Tên: A → Z</option>
              </select>
            </div>

            <!-- Filter Actions -->
            <div class="col-md-1">
              <div class="d-flex gap-1">
                <button type="submit" class="btn btn-primary btn-sm px-3" title="Áp dụng bộ lọc">
                  <i class="bi bi-funnel"></i>
                </button>
                <a href="/" class="btn btn-outline-secondary btn-sm px-3" title="Đặt lại bộ lọc">
                  <i class="bi bi-arrow-clockwise"></i>
                </a>
              </div>
            </div>
          </form>
        </div>
      </div>
      
      <div class="col-lg-12">
        <!-- Results Info - Only show when filters are applied -->
        <% 
          const hasFilters = query.brand || query.priceRange || query.category || query.sort || query.search;
        %>
        <% if (hasFilters && products.length > 0) { %>
          <div class="d-flex justify-content-between align-items-center mb-4">
            <div class="results-info">
              <span class="text-muted">
                Hiển thị <strong class="text-primary"><%= products.length %></strong> 
                trong tổng số <strong class="text-primary"><%= totalPages * 12 %></strong> sản phẩm
              </span>
            </div>
          </div>
        <% } else if (products.length > 0) { %>
          <div class="d-flex justify-content-between align-items-center mb-4">
            <p class="text-muted mb-0">
              Hiển thị <strong><%= products.length %></strong> sản phẩm
            </p>
          </div>
        <% } %>

        <% if (products.length === 0) { %>
          <div class="empty-state">
            <i class="bi bi-inbox"></i>
            <h3>Không tìm thấy sản phẩm</h3>
            <p class="text-muted">Thử thay đổi bộ lọc hoặc tìm kiếm với từ khóa khác</p>
            <a href="/" class="btn btn-primary">Xem tất cả sản phẩm</a>
          </div>
        <% } else { %>

          <div class="row g-3" id="productsContainer">
            <% products.forEach(product => { %>
              <div class="col-lg-3 col-md-6 col-sm-6 product-item">
                <div class="card h-100 product-card">
                  <div class="position-relative img-zoom">
                    <a href="/products/<%= product.slug %>" class="text-decoration-none">
                      <img src="<%= product.thumbnail || '/images/no-image.png' %>" class="product-image" alt="<%= product.title %>">
                      <% if (product.discountPercentage > 0) { %>
                        <span class="position-absolute top-0 start-0 m-2 badge bg-danger discount-badge">
                          Giảm <%= product.discountPercentage %>%
                        </span>
                      <% } %>
                      <!-- Sale Hot Badge -->
                      <div class="position-absolute top-0 end-0 m-2">
                        <div class="sale-hot-badge">
                          <span class="sale-text">Sale</span>
                          <span class="hot-text">Hot</span>
                        </div>
                      </div>
                    </a>
                  </div>
                  <div class="card-body d-flex flex-column p-3">
                    <a href="/products/<%= product.slug %>" class="text-decoration-none">
                      <h6 class="card-title mb-2 text-dark product-title">
                        <%= product.title %>
                      </h6>
                    </a>
                    
                    <!-- Price Section -->
                    <div class="price-section mb-2">
                      <% if (product.discountPercentage > 0) { %>
                        <div class="current-price text-danger fw-bold mb-1">
                          <%= (product.price * (1 - product.discountPercentage/100)).toLocaleString('vi-VN') %>₫
                        </div>
                        <div class="original-price text-muted text-decoration-line-through small">
                          <%= product.price.toLocaleString('vi-VN') %>₫
                        </div>
                      <% } else { %>
                        <div class="current-price text-danger fw-bold">
                          <%= product.price.toLocaleString('vi-VN') %>₫
                        </div>
                      <% } %>
                    </div>
                    
                    <!-- Rating and Wishlist -->
                    <div class="d-flex justify-content-between align-items-center mt-auto">
                      <div class="rating d-flex align-items-center">
                        <i class="bi bi-star-fill text-warning me-1"></i>
                        <span class="fw-bold">5</span>
                      </div>
                      <button class="btn btn-outline-primary btn-sm wishlist-btn" data-product-id="<%= product._id %>">
                        <i class="bi bi-heart me-1"></i>Yêu thích
                      </button>
                    </div>
                  </div>
                </div>
              </div>
            <% }) %>
          </div>
        <% } %>
        
        <% if (totalPages > 1) { %>
          <nav class="mt-5">
            <ul class="pagination justify-content-center">
              <% if (currentPage > 1) { %>
                <li class="page-item">
                  <a class="page-link" href="?page=<%= currentPage - 1 %>&<%= new URLSearchParams(query).toString() %>">
                    <i class="bi bi-chevron-left"></i>
                  </a>
                </li>
              <% } %>
              
              <% for(let i = 1; i <= totalPages; i++) { %>
                <% if (i === 1 || i === totalPages || (i >= currentPage - 2 && i <= currentPage + 2)) { %>
                  <li class="page-item <%= currentPage === i ? 'active' : '' %>">
                    <a class="page-link" href="?page=<%= i %>&<%= new URLSearchParams(query).toString() %>"><%= i %></a>
                  </li>
                <% } else if (i === currentPage - 3 || i === currentPage + 3) { %>
                  <li class="page-item disabled">
                    <span class="page-link">...</span>
                  </li>
                <% } %>
              <% } %>
              
              <% if (currentPage < totalPages) { %>
                <li class="page-item">
                  <a class="page-link" href="?page=<%= currentPage + 1 %>&<%= new URLSearchParams(query).toString() %>">
                    <i class="bi bi-chevron-right"></i>
                  </a>
                </li>
              <% } %>
            </ul>
          </nav>
        <% } %>
      </div>
    </div>
  </div>

  <%- include('partials/footer') %>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
  <script src="/js/main.js"></script>
  
  <style>
    /* Hero Section */
    .hero-section {
      background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
      padding: 4rem 0;
      margin-bottom: 3rem;
    }
    
    .hero-title {
      font-size: 3rem;
      font-weight: 700;
      line-height: 1.2;
    }
    
    .highlight {
      color: #ffd700;
    }
    
    .hero-subtitle {
      font-size: 1.2rem;
      opacity: 0.9;
    }
    
    .feature-item {
      display: flex;
      align-items: center;
      font-size: 0.9rem;
      opacity: 0.9;
    }
    
    /* Product card hover effects */
    .product-card {
      transition: all 0.3s ease;
      border: 1px solid #e9ecef;
      border-radius: 12px;
      overflow: hidden;
    }
    
    .product-card:hover {
      transform: translateY(-5px);
      box-shadow: 0 8px 25px rgba(0,0,0,0.1);
      border-color: #007bff;
    }
    
    .img-zoom img {
      transition: transform 0.3s ease;
      border-radius: 12px 12px 0 0;
    }
    
    .product-card:hover .img-zoom img {
      transform: scale(1.05);
    }
    
    /* Discount badge */
    .discount-badge {
      background: linear-gradient(135deg, #dc3545, #c82333) !important;
      border-radius: 8px;
      font-weight: bold;
      font-size: 0.75rem;
      padding: 4px 8px;
    }
    
    /* Sale Hot Badge */
    .sale-hot-badge {
      background: linear-gradient(135deg, #ffc107, #ff8c00);
      border-radius: 8px;
      padding: 2px 6px;
      font-size: 0.7rem;
      font-weight: bold;
      color: white;
      text-align: center;
      min-width: 40px;
    }
    
    .sale-text {
      display: block;
      line-height: 1;
    }
    
    .hot-text {
      display: block;
      line-height: 1;
      font-size: 0.6rem;
    }
    
    /* Product title */
    .product-title {
      height: 48px;
      overflow: hidden;
      display: -webkit-box;
      -webkit-line-clamp: 2;
      -webkit-box-orient: vertical;
      line-height: 1.4;
      font-weight: 500;
    }
    
    /* Price section */
    .price-section {
      min-height: 60px;
    }
    
    .current-price {
      font-size: 1.1rem !important;
    }
    
    /* Installment info */
    .installment-info {
      background: #f8f9fa;
      border-radius: 8px;
    }
    
    .installment-info small {
      font-size: 0.7rem;
      line-height: 1.3;
    }
    
    /* Rating and wishlist */
    .rating {
      font-size: 0.9rem;
    }
    
    .wishlist-btn {
      font-size: 0.8rem;
      padding: 4px 8px;
      border-radius: 6px;
      transition: all 0.3s ease;
    }
    
    .wishlist-btn:hover {
      background-color: #007bff;
      color: white;
      transform: translateY(-1px);
    }
    
    /* Responsive adjustments */
    @media (max-width: 1200px) {
      .col-lg-2 {
        flex: 0 0 auto;
        width: 20%;
      }
    }
    
    @media (max-width: 992px) {
      .col-lg-2 {
        flex: 0 0 auto;
        width: 33.333333%;
      }
      
      .hero-title {
        font-size: 2.5rem;
      }
    }
    
    @media (max-width: 768px) {
      .col-lg-2 {
        flex: 0 0 auto;
        width: 50%;
      }
      
      .hero-title {
        font-size: 2rem;
      }
      
      .hero-section {
        padding: 2rem 0;
      }
    }
    
    @media (max-width: 576px) {
      .col-lg-2 {
        flex: 0 0 auto;
        width: 100%;
      }
      
      .hero-title {
        font-size: 1.8rem;
      }
    }
    
    /* Empty state styling */
    .empty-state {
      text-align: center;
      padding: 4rem 2rem;
      color: #6c757d;
    }
    
    .empty-state i {
      font-size: 4rem;
      margin-bottom: 1rem;
      opacity: 0.5;
    }
    
    .empty-state h3 {
      margin-bottom: 1rem;
      color: #495057;
    }
    
    /* Filter bar improvements */
    .filter-bar {
      background: linear-gradient(135deg, #f8f9fa 0%, #e9ecef 100%);
    }
    
    /* Product title height consistency */
    .card-title {
      line-height: 1.4;
    }
  </style>
  
  <script>
  // Handle Wishlist buttons on home page
  document.querySelectorAll('.wishlist-btn').forEach(button => {
    button.addEventListener('click', async function(e) {
      e.preventDefault();
      e.stopPropagation();
      
      const productId = this.getAttribute('data-product-id');
      
      // Add visual feedback
      const originalHTML = this.innerHTML;
      this.innerHTML = '<i class="bi bi-heart-fill me-1"></i>Đã thích';
      this.classList.remove('btn-outline-primary');
      this.classList.add('btn-primary');
      
      // Show toast notification
      showToast('Đã thêm vào danh sách yêu thích!', 'success');
      
      // Reset button after 2 seconds
      setTimeout(() => {
        this.innerHTML = originalHTML;
        this.classList.remove('btn-primary');
        this.classList.add('btn-outline-primary');
      }, 2000);
    });
  });
  </script>
</body>
</html>
