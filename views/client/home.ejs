  <% if (flashSaleConfig) { %>
  <script>
    // Flash Sale Countdown
    const startDate = new Date('<%= flashSaleConfig.startDate %>').getTime();
    const endDate = new Date('<%= flashSaleConfig.endDate %>').getTime();
    const now = new Date().getTime();
    
    const countdownElement = document.getElementById('countdown-timer');
    
    if (countdownElement) {
      function updateCountdown() {
        const currentTime = new Date().getTime();
        const boxes = countdownElement.querySelectorAll('.countdown-box');
        
        if (!boxes || boxes.length === 0) return;
        
        // Sắp diễn ra - countdown đến khi bắt đầu
        if (currentTime < startDate) {
          const distance = startDate - currentTime;
          
          const days = Math.floor(distance / (1000 * 60 * 60 * 24));
          const hours = Math.floor((distance % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
          const minutes = Math.floor((distance % (1000 * 60 * 60)) / (1000 * 60));
          const seconds = Math.floor((distance % (1000 * 60)) / 1000);
          
          // Nếu có ngày, hiển thị ngày thay vì giờ
          if (days > 0) {
            boxes[0].querySelector('.countdown-number').textContent = days.toString().padStart(2, '0');
            boxes[0].querySelector('.countdown-unit').textContent = 'Ngày';
            boxes[1].querySelector('.countdown-number').textContent = hours.toString().padStart(2, '0');
            boxes[1].querySelector('.countdown-unit').textContent = 'Giờ';
            boxes[2].querySelector('.countdown-number').textContent = minutes.toString().padStart(2, '0');
            boxes[2].querySelector('.countdown-unit').textContent = 'Phút';
          } else {
            boxes[0].querySelector('.countdown-number').textContent = hours.toString().padStart(2, '0');
            boxes[0].querySelector('.countdown-unit').textContent = 'Giờ';
            boxes[1].querySelector('.countdown-number').textContent = minutes.toString().padStart(2, '0');
            boxes[1].querySelector('.countdown-unit').textContent = 'Phút';
            boxes[2].querySelector('.countdown-number').textContent = seconds.toString().padStart(2, '0');
            boxes[2].querySelector('.countdown-unit').textContent = 'Giây';
          }
        }
        // Đang diễn ra - countdown đến khi kết thúc
        else if (currentTime >= startDate && currentTime <= endDate) {
          const distance = endDate - currentTime;
          
          if (distance < 0) {
            countdownElement.innerHTML = '<div class="countdown-ended"><i class="bi bi-x-circle me-2"></i>ĐÃ KẾT THÚC</div>';
            return;
          }
          
          const hours = Math.floor((distance % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
          const minutes = Math.floor((distance % (1000 * 60 * 60)) / (1000 * 60));
          const seconds = Math.floor((distance % (1000 * 60)) / 1000);
          
          boxes[0].querySelector('.countdown-number').textContent = hours.toString().padStart(2, '0');
          boxes[1].querySelector('.countdown-number').textContent = minutes.toString().padStart(2, '0');
          boxes[2].querySelector('.countdown-number').textContent = seconds.toString().padStart(2, '0');
        }
      }
      
      updateCountdown();
      setInterval(updateCountdown, 1000);
    }

    // Hiển thị panel danh mục con khi hover
    document.addEventListener('DOMContentLoaded', function () {
      // Mapping các danh mục với panel tương ứng
      const categoryMappings = [
        { itemId: 'homeCatPhone', panelId: 'heroPhonePanel' },
        { itemId: 'homeCatiPhone', panelId: 'heroiPhonePanel' },
        { itemId: 'homeCatTablet', panelId: 'heroTabletPanel' },
        { itemId: 'homeCatApple', panelId: 'heroApplePanel' },
        { itemId: 'homeCatUsed', panelId: 'heroUsedPanel' },
        { itemId: 'homeCatWatch', panelId: 'heroWatchPanel' }
      ];

      categoryMappings.forEach(function(mapping) {
        var categoryItem = document.getElementById(mapping.itemId);
        var panel = document.getElementById(mapping.panelId);
        
        if (!categoryItem || !panel) return;

        var hideTimeout;

        function showPanel() {
          // Ẩn tất cả panel khác
          categoryMappings.forEach(function(otherMapping) {
            var otherPanel = document.getElementById(otherMapping.panelId);
            var otherItem = document.getElementById(otherMapping.itemId);
            if (otherPanel && otherMapping.panelId !== mapping.panelId) {
              otherPanel.classList.remove('show');
            }
            if (otherItem && otherMapping.itemId !== mapping.itemId) {
              otherItem.classList.remove('active');
            }
          });

          if (hideTimeout) clearTimeout(hideTimeout);
          panel.classList.add('show');
          categoryItem.classList.add('active');
        }

        function scheduleHide() {
          hideTimeout = setTimeout(function () {
            panel.classList.remove('show');
            categoryItem.classList.remove('active');
          }, 120);
        }

        categoryItem.addEventListener('mouseenter', showPanel);
        categoryItem.addEventListener('mouseleave', scheduleHide);
        panel.addEventListener('mouseenter', showPanel);
        panel.addEventListener('mouseleave', scheduleHide);
      });
    });
  </script>
  <% } %>
  
