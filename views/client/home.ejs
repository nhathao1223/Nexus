  <% if (flashSaleConfig && flashSaleConfig.isActive && flashSaleProducts && flashSaleProducts.length > 0) { %>
  <section class="flashsale-section">
    <div class="container">
      <div class="flashsale-inner position-relative">
        <div class="flashsale-ribbon">
          <span><%= flashSaleConfig.title || 'FLASH SALE MỖI NGÀY' %></span>
        </div>

        <div class="d-flex justify-content-between align-items-center mb-3">
          <div></div>
          <div class="flashsale-countdown-wrapper">
            <% 
              const now = new Date();
              const startDate = new Date(flashSaleConfig.startDate);
              const endDate = new Date(flashSaleConfig.endDate);
            %>
            <% if (now < startDate) { %>
              <div class="countdown-label">
                <i class="bi bi-hourglass-split me-2"></i>SẮP DIỄN RA
              </div>
              <div class="countdown-boxes" id="countdown-timer">
                <div class="countdown-box">
                  <span class="countdown-number">00</span>
                  <span class="countdown-unit">Giờ</span>
                </div>
                <span class="countdown-separator">:</span>
                <div class="countdown-box">
                  <span class="countdown-number">00</span>
                  <span class="countdown-unit">Phút</span>
                </div>
                <span class="countdown-separator">:</span>
                <div class="countdown-box">
                  <span class="countdown-number">00</span>
                  <span class="countdown-unit">Giây</span>
                </div>
              </div>
            <% } else if (now >= startDate && now <= endDate) { %>
              <div class="countdown-label">
                KẾT THÚC SAU
              </div>
              <div class="countdown-boxes" id="countdown-timer">
                <div class="countdown-box">
                  <span class="countdown-number">00</span>
                  <span class="countdown-unit">Giờ</span>
                </div>
                <span class="countdown-separator">:</span>
                <div class="countdown-box">
                  <span class="countdown-number">00</span>
                  <span class="countdown-unit">Phút</span>
                </div>
                <span class="countdown-separator">:</span>
                <div class="countdown-box">
                  <span class="countdown-number">00</span>
                  <span class="countdown-unit">Giây</span>
                </div>
              </div>
            <% } else { %>
              <div class="countdown-ended">
                <i class="bi bi-x-circle me-2"></i>ĐÃ KẾT THÚC
              </div>
            <% } %>
          </div>
        </div>

        <div class="flashsale-carousel position-relative">
          <button class="flashsale-arrow flashsale-arrow-left flash-sale-prev" type="button">
            <i class="bi bi-chevron-left"></i>
          </button>

          <div class="flash-sale-track d-flex gap-3">
            <% flashSaleProducts.forEach(product => { %>
              <div class="flashsale-item card">
                <div class="flashsale-img-container">
                  <a href="/products/<%= product.slug %>" class="text-decoration-none">
                    <img src="<%= product.thumbnail || '/images/no-image.png' %>" class="flashsale-product-image" alt="<%= product.title %>">
                    <% if (product.discountPercentage > 0) { %>
                      <span class="discount-badge">
                        Giảm <%= product.discountPercentage %>%
                      </span>
                    <% } %>
                    <span class="installment-badge">
                      Trả góp 0%
                    </span>
                  </a>
                </div>
                <div class="card-body">
                  <a href="/products/<%= product.slug %>" class="text-decoration-none">
                    <h6 class="card-title mb-2 text-dark product-title">
                      <%= product.title %>
                    </h6>
                  </a>
                  <div class="price-section">
                    <% const finalPrice = product.price * (1 - product.discountPercentage/100); %>
                    <div class="current-price text-danger fw-bold mb-1">
                      <%= finalPrice.toLocaleString('vi-VN') %>₫
                    </div>
                    <% if (product.discountPercentage > 0) { %>
                      <div class="original-price text-muted text-decoration-line-through small">
                        <%= product.price.toLocaleString('vi-VN') %>₫
                      </div>
                    <% } %>
                  </div>
                  <div class="rating d-flex align-items-center mt-2">
                    <% for (let i = 0; i < 5; i++) { %>
                      <% if (i < Math.floor(product.rating || 0)) { %>
                        <i class="bi bi-star-fill text-warning"></i>
                      <% } else { %>
                        <i class="bi bi-star text-warning"></i>
                      <% } %>
                    <% } %>
                    <span class="ms-2 text-muted small">(<%= product.reviewsCount || 0 %> đánh giá)</span>
                  </div>
                </div>
              </div>
            <% }) %>
          </div>

          <button class="flashsale-arrow flashsale-arrow-right flash-sale-next" type="button">
            <i class="bi bi-chevron-right"></i>
          </button>
        </div>
      </div>
    </div>
  </section>
  <% } %>

  <div class="container mt-4" id="products">
    <h2 class="mb-4">
      <i class="bi bi-grid-3x3-gap me-2"></i>Tất cả sản phẩm
    </h2>
    
    <div class="row">
      <div class="col-lg-12 mb-4">
        <!-- Filter Bar -->
        <div class="filter-bar bg-white p-3 rounded shadow-sm border">
          <form method="GET" class="row g-3 align-items-end">
            <!-- Brand Filter -->
            <div class="col-md-3">
              <label class="form-label fw-semibold text-muted small">Hãng:</label>
              <select class="form-select form-select-sm" name="brand">
                <option value="">Tất cả hãng</option>
                <option value="apple" <%= query.brand === 'apple' ? 'selected' : '' %>>Apple</option>
                <option value="samsung" <%= query.brand === 'samsung' ? 'selected' : '' %>>Samsung</option>
                <option value="xiaomi" <%= query.brand === 'xiaomi' ? 'selected' : '' %>>Xiaomi</option>
                <option value="oppo" <%= query.brand === 'oppo' ? 'selected' : '' %>>OPPO</option>
                <option value="vivo" <%= query.brand === 'vivo' ? 'selected' : '' %>>Vivo</option>
              </select>
            </div>

            <!-- Price Filter -->
            <div class="col-md-3">
              <label class="form-label fw-semibold text-muted small">Giá:</label>
              <select class="form-select form-select-sm" name="priceRange">
                <option value="">Tất cả mức giá</option>
                <option value="0-5" <%= query.priceRange === '0-5' ? 'selected' : '' %>>Dưới 5 triệu</option>
                <option value="5-10" <%= query.priceRange === '5-10' ? 'selected' : '' %>>5 - 10 triệu</option>
                <option value="10-20" <%= query.priceRange === '10-20' ? 'selected' : '' %>>10 - 20 triệu</option>
                <option value="20+" <%= query.priceRange === '20+' ? 'selected' : '' %>>Trên 20 triệu</option>
              </select>
            </div>

            <!-- Category Filter -->
            <div class="col-md-3">
              <label class="form-label fw-semibold text-muted small">Danh mục:</label>
              <select class="form-select form-select-sm" name="category">
                <option value="">Tất cả danh mục</option>
                <% categories.forEach(cat => { %>
                  <option value="<%= cat._id %>" <%= query.category === cat._id.toString() ? 'selected' : '' %>>
                    <%= cat.name %>
                  </option>
                <% }) %>
              </select>
            </div>

            <!-- Sort -->
            <div class="col-md-2">
              <label class="form-label fw-semibold text-muted small">Sắp xếp:</label>
              <select class="form-select form-select-sm" name="sort">
                <option value="">Mới nhất</option>
                <option value="price-asc" <%= query.sort === 'price-asc' ? 'selected' : '' %>>Giá: Thấp → Cao</option>
                <option value="price-desc" <%= query.sort === 'price-desc' ? 'selected' : '' %>>Giá: Cao → Thấp</option>
                <option value="name-asc" <%= query.sort === 'name-asc' ? 'selected' : '' %>>Tên: A → Z</option>
              </select>
            </div>

            <!-- Filter Actions -->
            <div class="col-md-1">
              <div class="d-flex gap-1">
                <button type="submit" class="btn btn-primary btn-sm px-3" title="Áp dụng bộ lọc">
                  <i class="bi bi-funnel"></i>
                </button>
                <a href="/" class="btn btn-outline-secondary btn-sm px-3" title="Đặt lại bộ lọc">
                  <i class="bi bi-arrow-clockwise"></i>
                </a>
              </div>
            </div>
          </form>
        </div>
      </div>
      
      <div class="col-lg-12">
        <!-- Results Info - Only show when filters are applied -->
        <% 
          const hasFilters = query.brand || query.priceRange || query.category || query.sort || query.search;
        %>
        <% if (hasFilters && products.length > 0) { %>
          <div class="d-flex justify-content-between align-items-center mb-4">
            <div class="results-info">
              <span class="text-muted">
                Hiển thị <strong class="text-primary"><%= products.length %></strong> 
                trong tổng số <strong class="text-primary"><%= totalPages * 12 %></strong> sản phẩm
              </span>
            </div>
          </div>
        <% } else if (products.length > 0) { %>
          <div class="d-flex justify-content-between align-items-center mb-4">
            <p class="text-muted mb-0">
              Hiển thị <strong><%= products.length %></strong> sản phẩm
            </p>
          </div>
        <% } %>

        <% if (products.length === 0) { %>
          <div class="empty-state">
            <i class="bi bi-inbox"></i>
            <h3>Không tìm thấy sản phẩm</h3>
            <p class="text-muted">Thử thay đổi bộ lọc hoặc tìm kiếm với từ khóa khác</p>
            <a href="/" class="btn btn-primary">Xem tất cả sản phẩm</a>
          </div>
        <% } else { %>

          <div class="row g-3" id="productsContainer">
            <% products.forEach(product => { %>
              <div class="col-lg-2-4 col-md-4 col-sm-6 product-item">
                <div class="card h-100 product-card">
                  <div class="position-relative img-zoom">
                    <a href="/products/<%= product.slug %>" class="text-decoration-none">
                      <img src="<%= product.thumbnail || '/images/no-image.png' %>" class="product-image" alt="<%= product.title %>">
                      <% if (product.discountPercentage > 0) { %>
                        <span class="position-absolute top-0 start-0 m-2 badge bg-danger discount-badge">
                          Giảm <%= product.discountPercentage %>%
                        </span>
                      <% } %>
                      <!-- Installment Badge -->
                      <div class="position-absolute top-0 end-0 m-2">
                        <span class="installment-badge-normal">
                          Trả góp 0%
                        </span>
                      </div>
                    </a>
                  </div>
                  <div class="card-body d-flex flex-column p-3">
                    <a href="/products/<%= product.slug %>" class="text-decoration-none">
                      <h6 class="card-title mb-2 text-dark product-title">
                        <%= product.title %>
                      </h6>
                    </a>
                    
                    <!-- Specs Section -->
                    <div class="specs-section mb-2">
                      <% if (product.screenSize || product.storage) { %>
                        <div class="d-flex gap-2 flex-wrap">
                          <% if (product.screenSize) { %>
                            <span class="badge bg-light text-dark border">
                              <%= product.screenSize %>
                            </span>
                          <% } %>
                          <% if (product.storage) { %>
                            <span class="badge bg-light text-dark border">
                              <%= product.storage %>
                            </span>
                          <% } %>
                        </div>
                      <% } %>
                    </div>
                    
                    <!-- Price Section -->
                    <div class="price-section mb-2">
                      <% if (product.discountPercentage > 0) { %>
                        <div class="current-price text-danger fw-bold mb-1">
                          <%= (product.price * (1 - product.discountPercentage/100)).toLocaleString('vi-VN') %>₫
                        </div>
                        <div class="original-price text-muted text-decoration-line-through small">
                          <%= product.price.toLocaleString('vi-VN') %>₫
                        </div>
                      <% } else { %>
                        <div class="current-price text-danger fw-bold">
                          <%= product.price.toLocaleString('vi-VN') %>₫
                        </div>
                      <% } %>
                    </div>
                    
                    <!-- Rating -->
                    <div class="rating d-flex align-items-center mt-auto">
                      <% for (let i = 0; i < 5; i++) { %>
                        <% if (i < Math.floor(product.rating || 0)) { %>
                          <i class="bi bi-star-fill text-warning"></i>
                        <% } else { %>
                          <i class="bi bi-star text-warning"></i>
                        <% } %>
                      <% } %>
                      <span class="ms-2 text-muted small">(<%= product.reviewsCount || 0 %> đánh giá)</span>
                    </div>
                  </div>
                </div>
              </div>
            <% }) %>
          </div>
        <% } %>
        
        <% if (totalPages > 1) { %>
          <nav class="mt-5">
            <ul class="pagination justify-content-center">
              <% if (currentPage > 1) { %>
                <li class="page-item">
                  <a class="page-link" href="?page=<%= currentPage - 1 %>&<%= new URLSearchParams(query).toString() %>">
                    <i class="bi bi-chevron-left"></i>
                  </a>
                </li>
              <% } %>
              
              <% for(let i = 1; i <= totalPages; i++) { %>
                <% if (i === 1 || i === totalPages || (i >= currentPage - 2 && i <= currentPage + 2)) { %>
                  <li class="page-item <%= currentPage === i ? 'active' : '' %>">
                    <a class="page-link" href="?page=<%= i %>&<%= new URLSearchParams(query).toString() %>"><%= i %></a>
                  </li>
                <% } else if (i === currentPage - 3 || i === currentPage + 3) { %>
                  <li class="page-item disabled">
                    <span class="page-link">...</span>
                  </li>
                <% } %>
              <% } %>
              
              <% if (currentPage < totalPages) { %>
                <li class="page-item">
                  <a class="page-link" href="?page=<%= currentPage + 1 %>&<%= new URLSearchParams(query).toString() %>">
                    <i class="bi bi-chevron-right"></i>
                  </a>
                </li>
              <% } %>
            </ul>
          </nav>
        <% } %>
      </div>
    </div>
  </div>

