<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Test MoMo Payment</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body>
  <div class="container mt-5">
    <div class="row justify-content-center">
      <div class="col-md-6">
        <div class="card">
          <div class="card-header">
            <h3>Test MoMo Payment</h3>
          </div>
          <div class="card-body">
            <form action="/test-momo-checkout" method="POST">
              <div class="mb-3">
                <label for="fullName" class="form-label">Họ tên</label>
                <input type="text" class="form-control" id="fullName" name="fullName" value="Nguyen Van A" required>
              </div>
              
              <div class="mb-3">
                <label for="phone" class="form-label">Số điện thoại</label>
                <input type="text" class="form-control" id="phone" name="phone" value="0123456789" required>
              </div>
              
              <div class="mb-3">
                <label for="address" class="form-label">Địa chỉ</label>
                <input type="text" class="form-control" id="address" name="address" value="123 Test Street" required>
              </div>
              
              <!-- Hidden fields with default values -->
              <input type="hidden" name="provinceCode" value="01">
              <input type="hidden" name="provinceName" value="Hà Nội">
              <input type="hidden" name="districtCode" value="001">
              <input type="hidden" name="districtName" value="Ba Đình">
              <input type="hidden" name="wardCode" value="00001">
              <input type="hidden" name="wardName" value="Phúc Xá">
              <input type="hidden" name="paymentMethod" value="momo">
              
              <button type="submit" class="btn btn-primary w-100">Test MoMo Payment</button>
            </form>
          </div>
        </div>
      </div>
    </div>
  </div>
</body>
</html>