<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> - NEXUS</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <%- include('partials/header') %>
  
  <div class="container mt-4">
    <div class="row">
      <div class="col-12">
        <h1 class="mb-4">
          <i class="bi bi-bag me-2"></i>Đơn hàng của tôi
        </h1>
        
        <% if (success_msg && success_msg.length > 0) { %>
          <div class="alert alert-success alert-dismissible fade show" role="alert">
            <%= success_msg %>
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
          </div>
        <% } %>
        
        <% if (error_msg && error_msg.length > 0) { %>
          <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <%= error_msg %>
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
          </div>
        <% } %>

        <% if (!orders || orders.length === 0) { %>
          <div class="text-center py-5">
            <i class="bi bi-bag-x" style="font-size: 4rem; color: #ccc;"></i>
            <h3 class="mt-3">Bạn chưa có đơn hàng nào</h3>
            <p class="text-muted">Hãy khám phá các sản phẩm tuyệt vời của chúng tôi</p>
            <a href="/products" class="btn btn-primary">Mua sắm ngay</a>
          </div>
        <% } else { %>
          <div class="row g-4">
            <% orders.forEach(order => { %>
              <div class="col-12">
                <div class="card">
                  <div class="card-header d-flex justify-content-between align-items-center">
                    <div>
                      <h6 class="mb-0">Đơn hàng #<%= order._id.toString().slice(-8).toUpperCase() %></h6>
                      <small class="text-muted">Đặt ngày <%= order.createdAt.toLocaleDateString('vi-VN') %></small>
                    </div>
                    <div>
                      <% if (order.status === 'pending') { %>
                        <span class="badge bg-warning text-dark">Chờ xác nhận</span>
                      <% } else if (order.status === 'confirmed') { %>
                        <span class="badge bg-info">Đã xác nhận</span>
                      <% } else if (order.status === 'shipping') { %>
                        <span class="badge bg-primary">Đang giao hàng</span>
                      <% } else if (order.status === 'delivered') { %>
                        <span class="badge bg-success">Đã giao hàng</span>
                      <% } else if (order.status === 'cancelled') { %>
                        <span class="badge bg-danger">Đã hủy</span>
                      <% } %>
                    </div>
                  </div>
                  <div class="card-body">
                    <div class="row align-items-center">
                      <div class="col-md-8">
                        <div class="d-flex align-items-center">
                          <div class="me-3">
                            <i class="bi bi-box-seam" style="font-size: 2rem; color: #6c757d;"></i>
                          </div>
                          <div>
                            <h6 class="mb-1">
                              <%= order.items.length %> sản phẩm
                            </h6>
                            <p class="text-muted mb-0">
                              Tổng tiền: <strong class="text-danger"><%= order.totalAmount.toLocaleString('vi-VN') %>₫</strong>
                            </p>
                          </div>
                        </div>
                      </div>
                      <div class="col-md-4 text-md-end">
                        <a href="/orders/<%= order._id %>" class="btn btn-outline-primary">
                          <i class="bi bi-eye me-1"></i>Xem chi tiết
                        </a>
                      </div>
                    </div>
                  </div>
                </div>
              </div>
            <% }) %>
          </div>

          <!-- Pagination -->
          <% if (totalPages > 1) { %>
            <nav class="mt-4">
              <ul class="pagination justify-content-center">
                <% if (currentPage > 1) { %>
                  <li class="page-item">
                    <a class="page-link" href="?page=<%= currentPage - 1 %>">Trước</a>
                  </li>
                <% } %>
                
                <% for(let i = 1; i <= totalPages; i++) { %>
                  <li class="page-item <%= currentPage === i ? 'active' : '' %>">
                    <a class="page-link" href="?page=<%= i %>"><%= i %></a>
                  </li>
                <% } %>
                
                <% if (currentPage < totalPages) { %>
                  <li class="page-item">
                    <a class="page-link" href="?page=<%= currentPage + 1 %>">Sau</a>
                  </li>
                <% } %>
              </ul>
            </nav>
          <% } %>
        <% } %>
      </div>
    </div>
  </div>

  <%- include('partials/footer') %>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
  <script src="/js/main.js"></script>
</body>
</html>