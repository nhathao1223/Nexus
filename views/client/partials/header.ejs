<!-- Header với logo ở trên -->
<div class="top-header">
  <div class="container">
    <div class="row align-items-center py-3">
      <div class="col-md-2">
        <a class="navbar-brand d-flex align-items-center" href="/">
          <span class="logo-simple"><span class="n-highlight">N</span>E<span class="x-highlight">X</span>US</span>
        </a>
      </div>
      <div class="col-md-7">
        <form class="d-flex" action="/products" method="GET">
          <div class="input-group search-group">
            <input class="form-control search-input" type="search" name="search" placeholder="Tìm kiếm sản phẩm..." aria-label="Search" value="<%= typeof query !== 'undefined' && query.search ? query.search : '' %>">
            <button class="btn search-btn" type="submit">
              <i class="bi bi-search"></i>
            </button>
          </div>
        </form>
      </div>
      <div class="col-md-3">
        <div class="d-flex justify-content-end align-items-center">
          <a class="header-link position-relative text-white me-3" href="/cart">
            <i class="bi bi-cart3"></i>
            <% if (typeof cartCount !== 'undefined' && cartCount > 0) { %>
              <span class="cart-badge" id="cart-counter">
                <%= cartCount %>
              </span>
            <% } %>
          </a>
          <% if (user) { %>
            <div class="dropdown">
              <a class="header-link dropdown-toggle d-flex align-items-center text-white" href="#" role="button" data-bs-toggle="dropdown">
                <i class="bi bi-person-circle me-1"></i>
                <span class="user-name">Đăng nhập</span>
              </a>
              <ul class="dropdown-menu dropdown-menu-end">
                <% if (user.role === 'admin') { %>
                  <li><a class="dropdown-item" href="/admin/dashboard">
                    <i class="bi bi-speedometer2 me-2"></i>Quản trị
                  </a></li>
                  <li><hr class="dropdown-divider"></li>
                <% } %>
                <li><a class="dropdown-item" href="/profile">
                  <i class="bi bi-person me-2"></i>Tài khoản
                </a></li>
                <li><a class="dropdown-item" href="/orders">
                  <i class="bi bi-bag me-2"></i>Đơn hàng
                </a></li>
                <li><hr class="dropdown-divider"></li>
                <li><a class="dropdown-item text-danger" href="/logout">
                  <i class="bi bi-box-arrow-right me-2"></i>Đăng xuất
                </a></li>
              </ul>
            </div>
          <% } else { %>
            <a class="header-link text-white" href="/login">
              <i class="bi bi-box-arrow-in-right me-1"></i>
              <span class="user-name">Đăng nhập</span>
            </a>
          <% } %>
        </div>
      </div>
    </div>
  </div>
</div>

