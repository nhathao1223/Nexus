<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> - NEXUS</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
  <link rel="stylesheet" href="/css/style.css">
  <link rel="stylesheet" href="/css/product-detail.css">
</head>
<body>
  <%- include('partials/header') %>
  
  <div class="container mt-3">
    <!-- Product Title & Basic Info -->
    <div class="row">
      <div class="col-12">
        <h1 class="product-main-title"><%= product.title %></h1>
       
      </div>
    </div>

    <div class="row mt-3">
      <!-- Left Column: Images & Specs -->
      <div class="col-lg-7">
        <!-- Product Gallery -->
        <div class="product-gallery-box">
          <!-- Main Image/Video Container -->
          <div class="main-image-wrapper">
            <div class="main-image-container">
              <!-- Loading Spinner -->
              <div class="gallery-loading" id="galleryLoading">
                <div class="spinner"></div>
              </div>
              
              <!-- Main Image -->
              <img id="mainImage" 
                   src="<%= product.thumbnail || '/images/no-image.png' %>" 
                   class="main-product-img active" 
                   alt="<%= product.title %>"
                   onload="hideGalleryLoading()">
              
              <!-- Main Video (hidden by default) -->
              <div id="mainVideo" class="main-video-container" style="display: none;">
                <video id="videoPlayer" class="main-product-video" controls>
                  <source src="" type="video/mp4">
                  Your browser does not support the video tag.
                </video>
                <div id="youtubePlayer" class="youtube-player"></div>
              </div>
              
              <!-- Navigation Arrows -->
              <button class="gallery-nav gallery-nav-prev" id="prevBtn" onclick="navigateGallery(-1)">
                <i class="bi bi-chevron-left"></i>
              </button>
              <button class="gallery-nav gallery-nav-next" id="nextBtn" onclick="navigateGallery(1)">
                <i class="bi bi-chevron-right"></i>
              </button>
              
              <!-- Media Counter -->
              <div class="media-counter">
                <span id="currentIndex">1</span> / <span id="totalMedia">1</span>
              </div>
              
              <!-- Current Media Info -->
              <div class="current-media-info">
                <span id="currentMediaType">Image</span>
              </div>
            </div>
          </div>
          
          <!-- Thumbnail Gallery -->
          <div class="thumbnail-gallery-container">
            <div class="thumbnail-gallery-grid" id="thumbnailGallery">
              <!-- Main thumbnail -->
              <div class="thumbnail-item active" 
                   data-type="image" 
                   data-src="<%= product.thumbnail || '/images/no-image.png' %>"
                   data-index="0"
                   data-media-type="image"
                   title="Ảnh chính: <%= product.title %>">>
                <img src="<%= product.thumbnail || '/images/no-image.png' %>" alt="<%= product.title %>">
                <div class="thumbnail-overlay"></div>
                <div class="primary-indicator">
                  <i class="bi bi-star-fill"></i>
                </div>
              </div>
              
              <!-- Additional images -->
              <% if (product.images && product.images.length > 0) { %>
                <% product.images.slice(0, 6).forEach(function(img, index) { %>
                  <div class="thumbnail-item" 
                       data-type="image" 
                       data-src="<%= img %>"
                       data-index="<%= index + 1 %>"
                       data-media-type="image"
                       title="Ảnh <%= index + 2 %>: <%= product.title %>">>
                    <img src="<%= img %>" alt="<%= product.title %>">
                    <div class="thumbnail-overlay"></div>
                  </div>
                <% }); %>
              <% } %>
              
              <!-- Product videos -->
              <% if (product.videos && product.videos.length > 0) { %>
                <% product.videos.forEach(function(video, index) { %>
                  <div class="thumbnail-item video-thumbnail" 
                       data-type="<%= video.type %>" 
                       data-src="<%= video.url %>"
                       data-video-id="<%= video.videoId || '' %>"
                       data-index="<%= (product.images ? product.images.length : 0) + index + 1 %>"
                       data-media-type="<%= video.type %>"
                       title="<%= video.type === 'youtube' ? 'YouTube' : 'Video MP4' %>: <%= video.title || 'Video ' + (index + 1) %>"></div>>
                    <img src="<%= video.thumbnail %>" alt="Video <%= index + 1 %>">
                    <div class="thumbnail-overlay">
                      <div class="play-icon">
                        <i class="bi bi-play-fill"></i>
                      </div>
                    </div>
                  </div>
                <% }); %>
              <% } %>
            </div>
          </div>
        </div>

        <!-- Commitment Section -->
        <div class="commitment-box mt-3">
          <h6 class="commitment-title">Nexus cam kết</h6>
          <div class="row g-2">
            <div class="col-6">
              <div class="commitment-item-small">
                <i class="bi bi-clock-history text-primary"></i>
                <span>Hư gì đổi nấy 12 tháng tại 2949 siêu thị toàn quốc</span>
              </div>
            </div>
            <div class="col-6">
              <div class="commitment-item-small">
                <i class="bi bi-box-seam text-success"></i>
                <span>Sản phẩm mới (Cẩn thành toàn trước khi mở hộp)</span>
              </div>
            </div>
            <div class="col-6">
              <div class="commitment-item-small">
                <i class="bi bi-shield-check text-info"></i>
                <span>Bảo hành chính hãng điện thoại 1 năm tại các trung tâm bảo hành Ủy quyền Apple</span>
              </div>
            </div>
            <div class="col-6">
              <div class="commitment-item-small">
                <i class="bi bi-arrow-repeat text-warning"></i>
                <span>Bộ sản phẩm gồm: Hộp, Sách hướng dẫn, Cáp, Cây lấy sim</span>
              </div>
            </div>
          </div>
        </div>

        <!-- Technical Specs Tabs -->
        <div class="specs-tabs-section mt-3">
          <ul class="nav nav-tabs specs-nav" role="tablist">
            <li class="nav-item">
              <button class="nav-link active" data-bs-toggle="tab" data-bs-target="#specs-tab">
                Thông số kỹ thuật
              </button>
            </li>
            <li class="nav-item">
              <button class="nav-link" data-bs-toggle="tab" data-bs-target="#info-tab">
                Thông tin sản phẩm
              </button>
            </li>
          </ul>
          
          <div class="tab-content specs-tab-content">
            <!-- Specs Tab -->
            <div class="tab-pane fade show active" id="specs-tab">
              <% if (product.specifications && product.specifications.size > 0) { %>
                <% 
                  // Group specifications by category
                  const specGroups = {};
                  const groupNames = {
                    'general': 'Cấu hình chung',
                    'display': 'Màn hình',
                    'camera': 'Camera',
                    'battery': 'Pin & Sạc',
                    'connectivity': 'Kết nối'
                  };
                  
                  // Get category specification fields to determine groups
                  let categoryFields = [];
                  if (product.category && product.category.specificationFields) {
                    categoryFields = product.category.specificationFields;
                  }
                  
                  // Group specs based on category fields
                  for (const [key, value] of product.specifications) {
                    const field = categoryFields.find(f => f.name === key);
                    const group = field ? field.group : 'general';
                    
                    if (!specGroups[group]) {
                      specGroups[group] = [];
                    }
                    
                    specGroups[group].push({
                      key,
                      value,
                      label: field ? field.label : key
                    });
                  }
                %>
                
                <% Object.keys(specGroups).forEach((groupKey, index) => { %>
                  <div class="spec-section">
                    <button class="spec-section-header" type="button" data-bs-toggle="collapse" data-bs-target="#specs<%= groupKey %>">
                      <span><%= groupNames[groupKey] || groupKey %></span>
                      <i class="bi bi-chevron-down"></i>
                    </button>
                    <div class="collapse <%= index === 0 ? 'show' : '' %>" id="specs<%= groupKey %>">
                      <div class="specs-grid">
                        <% specGroups[groupKey].forEach(spec => { %>
                          <div class="spec-row">
                            <span class="spec-label"><%= spec.label %>:</span>
                            <span class="spec-value"><%= spec.value %></span>
                          </div>
                        <% }); %>
                      </div>
                    </div>
                  </div>
                <% }); %>
              <% } else { %>
                <div class="text-center text-muted py-4">
                  <i class="bi bi-info-circle fs-1 mb-3"></i>
                  <p>Chưa có thông số kỹ thuật cho sản phẩm này</p>
                </div>
              <% } %>
            </div>
            
            <!-- Info Tab -->
            <div class="tab-pane fade" id="info-tab">
              <div class="product-description">
                <p><%= product.description || 'Chưa có mô tả chi tiết cho sản phẩm này.' %></p>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Right Column: Purchase Box -->
      <div class="col-lg-5">
        <div class="purchase-box">
          <!-- Storage Options -->
          <div class="storage-selector">
            <div class="storage-label">Dung lượng</div>
            <div class="storage-options-grid">
              <button class="storage-option">
                <span class="storage-size">256GB</span>
              </button>
              <button class="storage-option active">
                <span class="storage-size">512GB</span>
              </button>
              <button class="storage-option">
                <span class="storage-size">1TB</span>
              </button>
            </div>
          </div>

          <!-- Color Options -->
          <div class="color-selector mt-3">
            <div class="color-label">Màu sắc</div>
            <div class="color-options-grid">
              <button class="color-option active">
                <div class="color-preview" style="background: linear-gradient(135deg, #D4A574, #B8956A)"></div>
                <span class="color-name">Titan Sa Mạc</span>
              </button>
              <button class="color-option">
                <div class="color-preview" style="background: #E8E8E8"></div>
                <span class="color-name">Titan Tự Nhiên</span>
              </button>
              <button class="color-option">
                <div class="color-preview" style="background: #2C3E50"></div>
                <span class="color-name">Titan Xanh</span>
              </button>
              <button class="color-option">
                <div class="color-preview" style="background: #1a1a1a"></div>
                <span class="color-name">Titan Đen</span>
              </button>
            </div>
          </div>

          <!-- Promotions Box -->
          <div class="promotions-highlight mt-3">
            <button class="promo-header-toggle" type="button" data-bs-toggle="collapse" data-bs-target="#promoContent">
              <i class="bi bi-gift-fill me-2"></i>Khuyến mãi
              <i class="bi bi-chevron-down ms-auto"></i>
            </button>
            <div class="collapse show" id="promoContent">
              <div class="promo-content">
                <div class="promo-item-highlight">
                  <i class="bi bi-check-circle-fill text-success"></i>
                  <span>Giảm thêm 500.000₫ khi thanh toán qua VNPAY-QR</span>
                </div>
                <div class="promo-item-highlight">
                  <i class="bi bi-check-circle-fill text-success"></i>
                  <span>Thu cũ đổi mới: Giảm đến 2.000.000₫</span>
                </div>
                <div class="promo-item-highlight">
                  <i class="bi bi-check-circle-fill text-success"></i>
                  <span>Phiếu mua hàng Airpods trị giá 800.000₫</span>
                </div>
                <div class="promo-item-highlight">
                  <i class="bi bi-check-circle-fill text-success"></i>
                  <span>Phiếu mua hàng sim Vina Bưm Data 12T trị giá 500.000₫</span>
                </div>
                <div class="promo-item-highlight">
                  <i class="bi bi-check-circle-fill text-success"></i>
                  <span>Trả góp 0% qua thẻ tín dụng</span>
                </div>
              </div>
            </div>
          </div>

          <!-- Warranty Options -->
          <div class="warranty-section mt-3">
            <button class="warranty-header-toggle" type="button" data-bs-toggle="collapse" data-bs-target="#warrantyContent">
              <i class="bi bi-shield-check me-2"></i>Chọn gói bảo hành (tùy chọn)
              <i class="bi bi-chevron-down ms-auto"></i>
            </button>
            <div class="collapse show" id="warrantyContent">
              <div class="warranty-options">
                <div class="warranty-item">
                  <input type="radio" name="warranty" id="warranty1" value="0" checked>
                  <label for="warranty1" class="warranty-label">
                    <div class="warranty-info">
                      <div class="warranty-title">Không mua bảo hành mở rộng</div>
                      <div class="warranty-subtitle">Bảo hành theo nhà sản xuất - 12 tháng</div>
                    </div>
                  </label>
                </div>
                <div class="warranty-item">
                  <input type="radio" name="warranty" id="warranty2" value="700000">
                  <label for="warranty2" class="warranty-label">
                    <div class="warranty-info">
                      <div class="warranty-title">Gói bảo hiểm 1 đổi 1 - 11 tháng</div>
                      <div class="warranty-subtitle">- Bảo hành TGDĐ và 11 tháng bảo hiểm<br>- ĐỔI NGAY MÁY MỚI nếu có lỗi nhà sản xuất</div>
                      <div class="warranty-price-tag">+ 700.000₫</div>
                    </div>
                  </label>
                </div>
                <div class="warranty-item">
                  <input type="radio" name="warranty" id="warranty3" value="650000">
                  <label for="warranty3" class="warranty-label">
                    <div class="warranty-info">
                      <div class="warranty-title">Gói bảo hiểm mở rộng - 12 tháng</div>
                      <div class="warranty-subtitle">- Thêm 12 tháng bảo hành chính hãng<br>- MIỄN PHÍ sửa chữa nếu lỗi Nhà sản xuất</div>
                      <div class="warranty-price-tag">+ 650.000₫</div>
                    </div>
                  </label>
                </div>
              </div>
            </div>
          </div>

          <!-- Price Display -->
          <div class="final-price-box mt-3">
            <% 
              const basePrice = product.discountPercentage > 0 
                ? product.price * (1 - product.discountPercentage/100) 
                : product.price;
            %>
            <div class="final-price" id="finalPrice" data-base-price="<%= basePrice %>">
              <%= basePrice.toLocaleString('vi-VN') %>₫
            </div>
            <div class="vip-points">+<span id="vipPoints"><%= Math.floor(basePrice/1000) %></span> điểm tích lũy Quà Tặng VIP</div>
          </div>

          <!-- Action Buttons -->
          <div class="action-buttons-group mt-3">
            <button class="btn-buy-main" id="buyNowBtn" data-product-id="<%= product._id %>">
              Mua ngay
            </button>
            <div class="btn-secondary-group">
              <button class="btn-installment-main">
                <i class="bi bi-credit-card me-1"></i>Trả góp 0%
              </button>
              <button class="btn-add-to-cart" id="addToCartBtn" data-product-id="<%= product._id %>">
                <i class="bi bi-cart-plus"></i>
              </button>
            </div>
          </div>

          <!-- Additional Info -->
          <div class="additional-info mt-3">
            <div class="info-item">
              <i class="bi bi-telephone-fill text-danger"></i>
              <span>Gọi đặt mua: <strong>1900 232 460</strong> (8:00 - 21:30)</span>
            </div>
            <div class="info-item">
              <i class="bi bi-geo-alt-fill text-primary"></i>
              <span>Chọn địa chỉ nhận hàng để biết thời gian giao hàng</span>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Reviews -->
    <div class="reviews-section mt-5" id="reviews">
      <div class="reviews-box">
        <div class="reviews-header">
          <h4 class="section-heading mb-0">Đánh giá & Bình luận</h4>
          <div class="reviews-count">
            <span class="me-2"><strong><%= (product.rating || 0).toFixed ? (product.rating || 0).toFixed(1) : (product.rating || 0) %>/5</strong></span>
            <span>(<%= reviewsCount || 0 %> đánh giá)</span>
          </div>
        </div>

        <% if (success_msg && success_msg.length) { %>
          <div class="alert alert-success mt-3 mb-0"><%= success_msg[0] %></div>
        <% } %>
        <% if (error_msg && error_msg.length) { %>
          <div class="alert alert-danger mt-3 mb-0"><%= error_msg[0] %></div>
        <% } %>

        <div class="reviews-content mt-3">
          <% if (user) { %>
            <form class="review-form" method="POST" action="/products/<%= product.slug %>/reviews">
              <div class="review-form-row">
                <div class="review-user">
                  <i class="bi bi-person-circle"></i>
                  <div>
                    <div class="review-user-name"><%= user.fullName %></div>
                    <div class="review-user-sub">Chia sẻ trải nghiệm của bạn</div>
                  </div>
                </div>

                <div class="review-rating">
                  <label for="rating" class="form-label mb-1">Số sao</label>
                  <select class="form-select" name="rating" id="rating" required>
                    <option value="" selected disabled>Chọn</option>
                    <option value="5">5 - Rất tốt</option>
                    <option value="4">4 - Tốt</option>
                    <option value="3">3 - Bình thường</option>
                    <option value="2">2 - Tệ</option>
                    <option value="1">1 - Rất tệ</option>
                  </select>
                </div>
              </div>

              <div class="mt-3">
                <label for="comment" class="form-label mb-1">Bình luận</label>
                <textarea class="form-control" id="comment" name="comment" rows="3" maxlength="1000" placeholder="Viết cảm nhận của bạn..." required></textarea>
              </div>

              <div class="mt-3 d-flex justify-content-end">
                <button type="submit" class="btn btn-primary review-submit-btn">
                  Gửi đánh giá
                </button>
              </div>
            </form>
          <% } else { %>
            <div class="login-to-review">
              <div class="mb-2"><strong>Đăng nhập để đánh giá</strong></div>
              <div class="text-muted mb-3">Bạn cần đăng nhập để có thể bình luận và đánh giá sản phẩm.</div>
              <a href="/login" class="btn btn-outline-primary">Đăng nhập</a>
            </div>
          <% } %>

          <div class="reviews-list mt-4">
            <% if (reviews && reviews.length) { %>
              <% reviews.forEach(function(r) { %>
                <div class="review-item">
                  <div class="review-item-head">
                    <div class="review-item-user">
                      <i class="bi bi-person-circle"></i>
                      <div>
                        <div class="review-item-name"><%= r.userName %></div>
                        <div class="review-item-meta">
                          <span class="review-stars">
                            <% for (let i = 1; i <= 5; i++) { %>
                              <% if (i <= r.rating) { %>
                                <i class="bi bi-star-fill"></i>
                              <% } else { %>
                                <i class="bi bi-star"></i>
                              <% } %>
                            <% } %>
                          </span>
                          <span class="review-date"><%= new Date(r.createdAt).toLocaleString('vi-VN') %></span>
                        </div>
                      </div>
                    </div>
                  </div>
                  <div class="review-item-body"><%= r.comment %></div>
                </div>
              <% }); %>
            <% } else { %>
              <div class="reviews-empty text-muted">Chưa có đánh giá nào. Hãy là người đầu tiên!</div>
            <% } %>
          </div>
        </div>
      </div>
    </div>

    <!-- Related Products -->
    <% if (relatedProducts && relatedProducts.length > 0) { %>
      <div class="related-section mt-5">
        <h4 class="section-heading">Sản phẩm tương tự</h4>
        <div class="row g-3">
          <% relatedProducts.forEach(function(prod) { %>
            <div class="col-lg-3 col-md-4 col-6">
              <a href="/products/<%= prod.slug %>" class="text-decoration-none">
                <div class="related-product-card">
                  <div class="related-product-image">
                    <img src="<%= prod.thumbnail || '/images/no-image.png' %>" alt="<%= prod.title %>">
                  </div>
                  <div class="related-product-info">
                    <h6 class="related-product-name"><%= prod.title %></h6>
                    <div class="related-product-price">
                      <% if (prod.discountPercentage > 0) { %>
                        <span class="price-now"><%= (prod.price * (1 - prod.discountPercentage/100)).toLocaleString('vi-VN') %>₫</span>
                        <span class="price-before"><%= prod.price.toLocaleString('vi-VN') %>₫</span>
                      <% } else { %>
                        <span class="price-now"><%= prod.price.toLocaleString('vi-VN') %>₫</span>
                      <% } %>
                    </div>
                  </div>
                </div>
              </a>
            </div>
          <% }); %>
        </div>
      </div>
    <% } %>
  </div>

  <%- include('partials/footer') %>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
  <script src="/js/main.js"></script>
  <script src="/js/product-detail.js"></script>
</body>
</html>
