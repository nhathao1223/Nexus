<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> - NEXUS</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
  <link rel="stylesheet" href="/css/style.css">
  <link rel="stylesheet" href="/css/products.css">
</head>
<body>
  <%- include('partials/header') %>
  
  <div class="container mt-4">
    <h1 class="mb-4">
      <i class="bi bi-grid-3x3-gap me-2"></i>Tất cả sản phẩm
    </h1>
    
    <div class="row">
      <div class="col-lg-12 mb-4">
        <!-- Filter Bar -->
        <div class="filter-bar bg-white p-3 rounded shadow-sm border">
          <form method="GET" class="row g-3 align-items-end">
            <!-- Brand Filter -->
            <div class="col-md-3">
              <label class="form-label fw-semibold text-muted small">Hãng:</label>
              <select class="form-select form-select-sm" name="brand">
                <option value="">Tất cả hãng</option>
                <option value="apple" <%= query.brand === 'apple' ? 'selected' : '' %>>Apple</option>
                <option value="samsung" <%= query.brand === 'samsung' ? 'selected' : '' %>>Samsung</option>
                <option value="xiaomi" <%= query.brand === 'xiaomi' ? 'selected' : '' %>>Xiaomi</option>
                <option value="oppo" <%= query.brand === 'oppo' ? 'selected' : '' %>>OPPO</option>
                <option value="vivo" <%= query.brand === 'vivo' ? 'selected' : '' %>>Vivo</option>
              </select>
            </div>

            <!-- Price Filter -->
            <div class="col-md-3">
              <label class="form-label fw-semibold text-muted small">Giá:</label>
              <select class="form-select form-select-sm" name="priceRange">
                <option value="">Tất cả mức giá</option>
                <option value="0-5" <%= query.priceRange === '0-5' ? 'selected' : '' %>>Dưới 5 triệu</option>
                <option value="5-10" <%= query.priceRange === '5-10' ? 'selected' : '' %>>5 - 10 triệu</option>
                <option value="10-20" <%= query.priceRange === '10-20' ? 'selected' : '' %>>10 - 20 triệu</option>
                <option value="20+" <%= query.priceRange === '20+' ? 'selected' : '' %>>Trên 20 triệu</option>
              </select>
            </div>

            <!-- Category Filter -->
            <div class="col-md-3">
              <label class="form-label fw-semibold text-muted small">Danh mục:</label>
              <select class="form-select form-select-sm" name="category">
                <option value="">Tất cả danh mục</option>
                <% categories.forEach(cat => { %>
                  <option value="<%= cat._id %>" <%= query.category === cat._id.toString() ? 'selected' : '' %>>
                    <%= cat.name %>
                  </option>
                <% }) %>
              </select>
            </div>

            <!-- Sort -->
            <div class="col-md-2">
              <label class="form-label fw-semibold text-muted small">Sắp xếp:</label>
              <select class="form-select form-select-sm" name="sort">
                <option value="">Mới nhất</option>
                <option value="price-asc" <%= query.sort === 'price-asc' ? 'selected' : '' %>>Giá: Thấp → Cao</option>
                <option value="price-desc" <%= query.sort === 'price-desc' ? 'selected' : '' %>>Giá: Cao → Thấp</option>
                <option value="name-asc" <%= query.sort === 'name-asc' ? 'selected' : '' %>>Tên: A → Z</option>
              </select>
            </div>

            <!-- Filter Actions -->
            <div class="col-md-1">
              <div class="d-flex gap-1">
                <button type="submit" class="btn btn-primary btn-sm px-3" title="Áp dụng bộ lọc">
                  <i class="bi bi-funnel"></i>
                </button>
                <a href="/products" class="btn btn-outline-secondary btn-sm px-3" title="Đặt lại bộ lọc">
                  <i class="bi bi-arrow-clockwise"></i>
                </a>
              </div>
            </div>
          </form>
        </div>
      </div>
      
      <div class="col-lg-12">
        <!-- Results Info - Only show when filters are applied -->
        <% 
          const hasFilters = query.brand || query.priceRange || query.category || query.sort || query.search;
        %>
        <% if (hasFilters && products.length > 0) { %>
          <div class="d-flex justify-content-between align-items-center mb-4">
            <div class="results-info">
              <span class="text-muted">
                Hiển thị <strong class="text-primary"><%= products.length %></strong> 
                trong tổng số <strong class="text-primary"><%= totalPages * 12 %></strong> sản phẩm
              </span>
            </div>
          </div>
        <% } else if (products.length > 0) { %>
          <div class="d-flex justify-content-between align-items-center mb-4">
            <p class="text-muted mb-0">
              Hiển thị <strong><%= products.length %></strong> sản phẩm
            </p>
          </div>
        <% } %>
        
        <% if (products.length === 0) { %>
          <div class="empty-state">
            <i class="bi bi-inbox"></i>
            <h3>Không tìm thấy sản phẩm</h3>
            <p class="text-muted">Thử thay đổi bộ lọc hoặc tìm kiếm với từ khóa khác</p>
            <a href="/products" class="btn btn-primary">Xem tất cả sản phẩm</a>
          </div>
        <% } else { %>

          <div class="row g-3" id="productsContainer">
            <% products.forEach(product => { %>
              <div class="col-lg-2-4 col-md-4 col-sm-6 product-item">
                <div class="card h-100 product-card">
                  <div class="position-relative img-zoom">
                    <a href="/products/<%= product.slug %>" class="text-decoration-none">
                      <img src="<%= publicUrl(product.thumbnail) %>" class="product-image" alt="<%= product.title %>">
                      <% if (product.discountPercentage > 0) { %>
                        <span class="position-absolute top-0 start-0 m-2 badge bg-danger discount-badge">
                          Giảm <%= product.discountPercentage %>%
                        </span>
                      <% } %>
                      <!-- Installment Badge -->
                      <div class="position-absolute top-0 end-0 m-2">
                        <span class="installment-badge-normal">
                          Trả góp 0%
                        </span>
                      </div>
                    </a>
                  </div>
                  <div class="card-body d-flex flex-column p-3">
                    <a href="/products/<%= product.slug %>" class="text-decoration-none">
                      <h6 class="card-title mb-2 text-dark product-title">
                        <%= product.title %>
                      </h6>
                    </a>
                    
                    <!-- Specs Section -->
                    <div class="specs-section mb-2">
                      <% if (product.screenSize || product.storage) { %>
                        <div class="d-flex gap-2 flex-wrap">
                          <% if (product.screenSize) { %>
                            <span class="badge bg-light text-dark border">
                              <%= product.screenSize %>
                            </span>
                          <% } %>
                          <% if (product.storage) { %>
                            <span class="badge bg-light text-dark border">
                              <%= product.storage %>
                            </span>
                          <% } %>
                        </div>
                      <% } %>
                    </div>
                    
                    <!-- Price Section -->
                    <div class="price-section mb-2">
                      <% if (product.discountPercentage > 0) { %>
                        <div class="current-price text-danger fw-bold mb-1">
                          <%= (product.price * (1 - product.discountPercentage/100)).toLocaleString('vi-VN') %>₫
                        </div>
                        <div class="original-price text-muted text-decoration-line-through small">
                          <%= product.price.toLocaleString('vi-VN') %>₫
                        </div>
                      <% } else { %>
                        <div class="current-price text-danger fw-bold">
                          <%= product.price.toLocaleString('vi-VN') %>₫
                        </div>
                      <% } %>
                    </div>
                    
                    <!-- Rating -->
                    <div class="rating d-flex align-items-center mt-auto">
                      <% for (let i = 0; i < 5; i++) { %>
                        <% if (i < Math.floor(product.rating || 0)) { %>
                          <i class="bi bi-star-fill text-warning"></i>
                        <% } else { %>
                          <i class="bi bi-star text-warning"></i>
                        <% } %>
                      <% } %>
                      <span class="ms-2 text-muted small">(<%= product.reviewsCount || 0 %> đánh giá)</span>
                    </div>
                  </div>
                </div>
              </div>
            <% }) %>
          </div>
        <% } %>
        
        <% if (totalPages > 1) { %>
          <nav class="mt-5">
            <ul class="pagination justify-content-center">
              <% if (currentPage > 1) { %>
                <li class="page-item">
                  <a class="page-link" href="?page=<%= currentPage - 1 %>&<%= new URLSearchParams(query).toString() %>">
                    <i class="bi bi-chevron-left"></i>
                  </a>
                </li>
              <% } %>
              
              <% for(let i = 1; i <= totalPages; i++) { %>
                <% if (i === 1 || i === totalPages || (i >= currentPage - 2 && i <= currentPage + 2)) { %>
                  <li class="page-item <%= currentPage === i ? 'active' : '' %>">
                    <a class="page-link" href="?page=<%= i %>&<%= new URLSearchParams(query).toString() %>"><%= i %></a>
                  </li>
                <% } else if (i === currentPage - 3 || i === currentPage + 3) { %>
                  <li class="page-item disabled">
                    <span class="page-link">...</span>
                  </li>
                <% } %>
              <% } %>
              
              <% if (currentPage < totalPages) { %>
                <li class="page-item">
                  <a class="page-link" href="?page=<%= currentPage + 1 %>&<%= new URLSearchParams(query).toString() %>">
                    <i class="bi bi-chevron-right"></i>
                  </a>
                </li>
              <% } %>
            </ul>
          </nav>
        <% } %>
      </div>
    </div>
  </div>

  <%- include('partials/footer') %>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
  <script src="/js/main.js"></script>
  
  <style>
    /* Product card hover effects */
    .product-card {
      transition: all 0.3s ease;
      border: 1px solid #e9ecef;
      border-radius: 12px;
      overflow: hidden;
      height: 100%;
    }
    
    .product-card:hover {
      transform: translateY(-5px);
      box-shadow: 0 8px 25px rgba(0,0,0,0.1);
      border-color: #007bff;
    }
    
    .img-zoom img {
      transition: transform 0.3s ease;
      border-radius: 12px 12px 0 0;
    }
    
    .product-card:hover .img-zoom img {
      transform: scale(1.05);
    }
    
    /* Discount badge */
    .discount-badge {
      background: linear-gradient(135deg, #dc3545, #c82333) !important;
      border-radius: 8px;
      font-weight: bold;
      font-size: 0.75rem;
      padding: 4px 8px;
      z-index: 2;
    }
    
    /* Product title - Fixed height to prevent text overflow */
    .product-title {
      height: 50px;
      overflow: hidden;
      display: -webkit-box;
      -webkit-line-clamp: 2;
      line-clamp: 2;
      -webkit-box-orient: vertical;
      line-height: 1.4;
      font-weight: 500;
      font-size: 0.95rem;
    }
    
    /* Price section - Fixed height */
    .price-section {
      min-height: 50px;
      display: flex;
      flex-direction: column;
      justify-content: center;
    }
    
    .current-price {
      font-size: 1.1rem !important;
      font-weight: 700 !important;
    }
    
    .original-price {
      font-size: 0.85rem;
    }
    
    /* Installment info - Better text wrapping */
    .installment-info {
      background: #f8f9fa;
      border-radius: 8px;
      min-height: 45px;
      display: flex;
      align-items: center;
    }
    
    .installment-text {
      font-size: 0.7rem;
      line-height: 1.2;
      word-wrap: break-word;
      hyphens: auto;
    }
    
    /* Rating and wishlist */
    .rating {
      font-size: 0.9rem;
    }
    
    .wishlist-btn {
      font-size: 0.75rem;
      padding: 4px 8px;
      border-radius: 6px;
      transition: all 0.3s ease;
      white-space: nowrap;
    }
    
    .wishlist-btn:hover {
      background-color: #007bff;
      color: white;
      transform: translateY(-1px);
    }
    
    /* Card body spacing */
    .card-body {
      padding: 1rem !important;
      display: flex;
      flex-direction: column;
      justify-content: space-between;
    }
    
    /* Responsive adjustments */
    @media (max-width: 1200px) {
      .product-title {
        font-size: 0.9rem;
        height: 45px;
      }
      
      .current-price {
        font-size: 1rem !important;
      }
      
      .installment-text {
        font-size: 0.65rem;
      }
    }
    
    @media (max-width: 992px) {
      .product-title {
        font-size: 0.85rem;
        height: 40px;
      }
      
      .current-price {
        font-size: 0.95rem !important;
      }
      
      .installment-text {
        font-size: 0.6rem;
      }
      
      .wishlist-btn {
        font-size: 0.7rem;
        padding: 3px 6px;
      }
    }
    
    @media (max-width: 768px) {
      .col-lg-3 {
        flex: 0 0 auto;
        width: 50%;
      }
      
      .product-title {
        height: 38px;
      }
      
      .installment-info {
        min-height: 40px;
      }
    }
    
    @media (max-width: 576px) {
      .col-lg-3 {
        flex: 0 0 auto;
        width: 100%;
      }
      
      .product-title {
        height: 45px;
        font-size: 0.9rem;
      }
      
      .current-price {
        font-size: 1.1rem !important;
      }
      
      .installment-text {
        font-size: 0.7rem;
      }
    }
    
    /* Empty state styling */
    .empty-state {
      text-align: center;
      padding: 4rem 2rem;
      color: #6c757d;
    }
    
    .empty-state i {
      font-size: 4rem;
      margin-bottom: 1rem;
      opacity: 0.5;
    }
    
    .empty-state h3 {
      margin-bottom: 1rem;
      color: #495057;
    }
    
    /* Filter bar improvements */
    .filter-bar {
      background: linear-gradient(135deg, #f8f9fa 0%, #e9ecef 100%);
    }
  </style>
  
  <script>
  // Handle Wishlist buttons on products page
  document.querySelectorAll('.wishlist-btn').forEach(button => {
    button.addEventListener('click', async function(e) {
      e.preventDefault();
      e.stopPropagation();
      
      const productId = this.getAttribute('data-product-id');
      
      // Add visual feedback
      const originalHTML = this.innerHTML;
      this.innerHTML = '<i class="bi bi-heart-fill me-1"></i>Đã thích';
      this.classList.remove('btn-outline-primary');
      this.classList.add('btn-primary');
      
      // Show toast notification
      showToast('Đã thêm vào danh sách yêu thích!', 'success');
      
      // Reset button after 2 seconds
      setTimeout(() => {
        this.innerHTML = originalHTML;
        this.classList.remove('btn-primary');
        this.classList.add('btn-outline-primary');
      }, 2000);
    });
  });

  // Toast notification function
  function showToast(message, type = 'success') {
    // Create toast container if it doesn't exist
    if (!document.getElementById('toast-container')) {
      const toastContainer = document.createElement('div');
      toastContainer.id = 'toast-container';
      toastContainer.className = 'toast-container position-fixed top-0 end-0 p-3';
      toastContainer.style.zIndex = '9999';
      document.body.appendChild(toastContainer);
    }

    const toastContainer = document.getElementById('toast-container');
    const toastId = 'toast-' + Date.now();
    const bgClass = type === 'success' ? 'bg-success' : 'bg-danger';
    const icon = type === 'success' ? 'bi-check-circle' : 'bi-exclamation-triangle';

    const toastHTML = `
      <div id="${toastId}" class="toast align-items-center text-white ${bgClass} border-0" role="alert" aria-live="assertive" aria-atomic="true">
        <div class="d-flex">
          <div class="toast-body">
            <i class="bi ${icon} me-2"></i>
            ${message}
          </div>
          <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast" aria-label="Close"></button>
        </div>
      </div>
    `;

    toastContainer.insertAdjacentHTML('beforeend', toastHTML);
    
    const toastElement = document.getElementById(toastId);
    const toast = new bootstrap.Toast(toastElement, {
      autohide: true,
      delay: 3000
    });
    
    toast.show();
    
    // Remove toast element after it's hidden
    toastElement.addEventListener('hidden.bs.toast', function() {
      this.remove();
    });
  }
  </script>
</body>
</html>
