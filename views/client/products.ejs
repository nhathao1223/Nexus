<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> - E-Commerce</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <%- include('partials/header') %>
  
  <div class="container mt-4">
    <h1 class="mb-4">
      <i class="bi bi-grid-3x3-gap me-2"></i>Tất cả sản phẩm
    </h1>
    
    <div class="row">
      <div class="col-lg-12 mb-4">
        <!-- Filter Bar -->
        <div class="filter-bar bg-white p-3 rounded shadow-sm border">
          <form method="GET" class="row g-3 align-items-end">
            <!-- Brand Filter -->
            <div class="col-md-3">
              <label class="form-label fw-semibold text-muted small">Hãng:</label>
              <select class="form-select form-select-sm" name="brand">
                <option value="">Tất cả hãng</option>
                <option value="apple" <%= query.brand === 'apple' ? 'selected' : '' %>>Apple</option>
                <option value="samsung" <%= query.brand === 'samsung' ? 'selected' : '' %>>Samsung</option>
                <option value="xiaomi" <%= query.brand === 'xiaomi' ? 'selected' : '' %>>Xiaomi</option>
                <option value="oppo" <%= query.brand === 'oppo' ? 'selected' : '' %>>OPPO</option>
                <option value="vivo" <%= query.brand === 'vivo' ? 'selected' : '' %>>Vivo</option>
              </select>
            </div>

            <!-- Price Filter -->
            <div class="col-md-3">
              <label class="form-label fw-semibold text-muted small">Giá:</label>
              <select class="form-select form-select-sm" name="priceRange">
                <option value="">Tất cả mức giá</option>
                <option value="0-5" <%= query.priceRange === '0-5' ? 'selected' : '' %>>Dưới 5 triệu</option>
                <option value="5-10" <%= query.priceRange === '5-10' ? 'selected' : '' %>>5 - 10 triệu</option>
                <option value="10-20" <%= query.priceRange === '10-20' ? 'selected' : '' %>>10 - 20 triệu</option>
                <option value="20+" <%= query.priceRange === '20+' ? 'selected' : '' %>>Trên 20 triệu</option>
              </select>
            </div>

            <!-- Category Filter -->
            <div class="col-md-3">
              <label class="form-label fw-semibold text-muted small">Danh mục:</label>
              <select class="form-select form-select-sm" name="category">
                <option value="">Tất cả danh mục</option>
                <% categories.forEach(cat => { %>
                  <option value="<%= cat._id %>" <%= query.category === cat._id.toString() ? 'selected' : '' %>>
                    <%= cat.name %>
                  </option>
                <% }) %>
              </select>
            </div>

            <!-- Sort -->
            <div class="col-md-2">
              <label class="form-label fw-semibold text-muted small">Sắp xếp:</label>
              <select class="form-select form-select-sm" name="sort">
                <option value="">Mới nhất</option>
                <option value="price-asc" <%= query.sort === 'price-asc' ? 'selected' : '' %>>Giá: Thấp → Cao</option>
                <option value="price-desc" <%= query.sort === 'price-desc' ? 'selected' : '' %>>Giá: Cao → Thấp</option>
                <option value="name-asc" <%= query.sort === 'name-asc' ? 'selected' : '' %>>Tên: A → Z</option>
              </select>
            </div>

            <!-- Filter Actions -->
            <div class="col-md-1">
              <div class="d-flex gap-1">
                <button type="submit" class="btn btn-primary btn-sm px-3" title="Áp dụng bộ lọc">
                  <i class="bi bi-funnel"></i>
                </button>
                <a href="/products" class="btn btn-outline-secondary btn-sm px-3" title="Đặt lại bộ lọc">
                  <i class="bi bi-arrow-clockwise"></i>
                </a>
              </div>
            </div>
          </form>
        </div>
      </div>
      
      <div class="col-lg-12">
        <!-- Results Info - Only show when filters are applied -->
        <% 
          const hasFilters = query.brand || query.priceRange || query.category || query.sort || query.search;
        %>
        <% if (hasFilters && products.length > 0) { %>
          <div class="d-flex justify-content-between align-items-center mb-4">
            <div class="results-info">
              <span class="text-muted">
                Hiển thị <strong class="text-primary"><%= products.length %></strong> 
                trong tổng số <strong class="text-primary"><%= totalPages * 12 %></strong> sản phẩm
              </span>
            </div>
          </div>
        <% } else if (products.length > 0) { %>
          <div class="d-flex justify-content-between align-items-center mb-4">
            <p class="text-muted mb-0">
              Hiển thị <strong><%= products.length %></strong> sản phẩm
            </p>
          </div>
        <% } %>
        
        <% if (products.length === 0) { %>
          <div class="empty-state">
            <i class="bi bi-inbox"></i>
            <h3>Không tìm thấy sản phẩm</h3>
            <p class="text-muted">Thử thay đổi bộ lọc hoặc tìm kiếm với từ khóa khác</p>
            <a href="/products" class="btn btn-primary">Xem tất cả sản phẩm</a>
          </div>
        <% } else { %>

          <div class="row g-4" id="productsContainer">
            <% products.forEach(product => { %>
              <div class="col-lg-4 col-md-6 product-item">
                <a href="/products/<%= product.slug %>" class="text-decoration-none">
                  <div class="card h-100 product-card">
                    <div class="position-relative img-zoom">
                      <img src="<%= product.thumbnail || '/images/no-image.png' %>" class="card-img-top" alt="<%= product.title %>">
                      <% if (product.discountPercentage > 0) { %>
                        <span class="position-absolute top-0 end-0 m-2 badge bg-danger">
                          -<%= product.discountPercentage %>%
                        </span>
                      <% } %>
                    </div>
                    <div class="card-body d-flex flex-column">
                      <p class="text-muted small mb-2">
                        <i class="bi bi-tag me-1"></i><%= product.category.name %>
                      </p>
                      <h5 class="card-title mb-3 text-dark"><%= product.title %></h5>
                      <div class="mt-auto">
                        <% if (product.discountPercentage > 0) { %>
                          <div class="mb-2">
                            <span class="text-decoration-line-through text-muted">
                              <%= product.price.toLocaleString('vi-VN') %>₫
                            </span>
                          </div>
                          <h4 class="text-danger mb-0">
                            <%= (product.price * (1 - product.discountPercentage/100)).toLocaleString('vi-VN') %>₫
                          </h4>
                        <% } else { %>
                          <h4 class="text-danger mb-0">
                            <%= product.price.toLocaleString('vi-VN') %>₫
                          </h4>
                        <% } %>
                      </div>
                    </div>
                  </div>
                </a>
              </div>
            <% }) %>
          </div>
        <% } %>
        
        <% if (totalPages > 1) { %>
          <nav class="mt-5">
            <ul class="pagination justify-content-center">
              <% if (currentPage > 1) { %>
                <li class="page-item">
                  <a class="page-link" href="?page=<%= currentPage - 1 %>&<%= new URLSearchParams(query).toString() %>">
                    <i class="bi bi-chevron-left"></i>
                  </a>
                </li>
              <% } %>
              
              <% for(let i = 1; i <= totalPages; i++) { %>
                <% if (i === 1 || i === totalPages || (i >= currentPage - 2 && i <= currentPage + 2)) { %>
                  <li class="page-item <%= currentPage === i ? 'active' : '' %>">
                    <a class="page-link" href="?page=<%= i %>&<%= new URLSearchParams(query).toString() %>"><%= i %></a>
                  </li>
                <% } else if (i === currentPage - 3 || i === currentPage + 3) { %>
                  <li class="page-item disabled">
                    <span class="page-link">...</span>
                  </li>
                <% } %>
              <% } %>
              
              <% if (currentPage < totalPages) { %>
                <li class="page-item">
                  <a class="page-link" href="?page=<%= currentPage + 1 %>&<%= new URLSearchParams(query).toString() %>">
                    <i class="bi bi-chevron-right"></i>
                  </a>
                </li>
              <% } %>
            </ul>
          </nav>
        <% } %>
      </div>
    </div>
  </div>

  <%- include('partials/footer') %>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
  <script src="/js/main.js"></script>
  
  <script>
  // No additional JavaScript needed
  </script>
</body>
</html>
