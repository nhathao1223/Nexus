<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> - Admin</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
</head>
<body>
  <%- include('../partials/navbar') %>

  <div class="container-fluid">
    <div class="row">
      <%- include('../partials/sidebar') %>

      <main class="col-md-10 ms-sm-auto px-md-4">
        <div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-3 pb-2 mb-3 border-bottom">
          <h1 class="h2">
            <i class="bi bi-lightning-fill text-warning me-2"></i>Quản lý Flash Sale
          </h1>
        </div>

        <% if (success_msg && success_msg.length > 0) { %>
          <div class="alert alert-success alert-dismissible fade show" role="alert">
            <%= success_msg %>
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
          </div>
        <% } %>

        <% if (error_msg && error_msg.length > 0) { %>
          <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <%= error_msg %>
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
          </div>
        <% } %>

        <!-- Flash Sale Time Settings -->
        <div class="card mb-4">
          <div class="card-header bg-warning">
            <h5 class="mb-0">
              <i class="bi bi-clock-history me-2"></i>Cài đặt thời gian Flash Sale
            </h5>
          </div>
          <div class="card-body">
            <div class="alert alert-info mb-3">
              <h6 class="alert-heading">
                <i class="bi bi-info-circle me-2"></i>Hướng dẫn sử dụng:
              </h6>
              <ul class="mb-0 small">
                <li><strong>Kích hoạt Flash Sale:</strong> Bật để hiển thị section Flash Sale trên trang chủ. Tắt để ẩn hoàn toàn.</li>
                <li><strong>Thời gian:</strong> Áp dụng cho TẤT CẢ sản phẩm Flash Sale. Countdown sẽ hiển thị trên trang chủ.</li>
                <li><strong>Thêm sản phẩm:</strong> Chọn sản phẩm từ dropdown bên dưới và click "Thêm vào Flash Sale".</li>
              </ul>
            </div>
            <form action="/admin/flashsale/update-config" method="POST">
              <div class="row">
                <div class="col-md-4">
                  <div class="mb-3">
                    <label class="form-label fw-bold">Ngày giờ bắt đầu</label>
                    <input type="datetime-local" 
                           name="startDate" 
                           class="form-control" 
                           value="<%= config.startDate ? new Date(config.startDate.getTime() - config.startDate.getTimezoneOffset() * 60000).toISOString().slice(0, 16) : '' %>"
                           required>
                  </div>
                </div>
                <div class="col-md-4">
                  <div class="mb-3">
                    <label class="form-label fw-bold">Ngày giờ kết thúc</label>
                    <input type="datetime-local" 
                           name="endDate" 
                           class="form-control" 
                           value="<%= config.endDate ? new Date(config.endDate.getTime() - config.endDate.getTimezoneOffset() * 60000).toISOString().slice(0, 16) : '' %>"
                           required>
                  </div>
                </div>
                <div class="col-md-4">
                  <label class="form-label fw-bold">Trạng thái</label>
                  <div class="d-flex gap-3 align-items-center">
                    <div class="form-check form-switch">
                      <input class="form-check-input" 
                             type="checkbox" 
                             name="isActive" 
                             id="isActive"
                             <%= config.isActive ? 'checked' : '' %>>
                      <label class="form-check-label" for="isActive">
                        Kích hoạt Flash Sale
                      </label>
                    </div>
                  </div>
                </div>
              </div>
              <div class="alert alert-warning mb-3">
                <i class="bi bi-exclamation-triangle me-2"></i>
                <strong>Lưu ý:</strong> Thời gian này áp dụng cho tất cả sản phẩm Flash Sale. 
                Countdown sẽ hiển thị trên trang chủ. Khi TẮT "Kích hoạt Flash Sale", toàn bộ section sẽ ẩn.
              </div>
              <button type="submit" class="btn btn-warning">
                <i class="bi bi-check-circle me-2"></i>Lưu cài đặt thời gian
              </button>
            </form>
          </div>
        </div>

        <!-- Flash Sale Status -->
        <div class="row mb-4">
          <div class="col-12">
            <div class="card">
              <div class="card-body">
                <div class="row align-items-center">
                  <div class="col-md-8">
                    <h5 class="mb-2">
                      <i class="bi bi-clock-history me-2"></i>Trạng thái Flash Sale
                    </h5>
                    <% 
                      const now = new Date();
                      const startDate = new Date(config.startDate);
                      const endDate = new Date(config.endDate);
                      let statusText = '';
                      let statusClass = '';
                      let statusIcon = '';
                      
                      if (now < startDate) {
                        statusText = 'Sắp diễn ra';
                        statusClass = 'bg-info';
                        statusIcon = 'bi-hourglass-split';
                      } else if (now >= startDate && now <= endDate) {
                        statusText = 'Đang diễn ra';
                        statusClass = 'bg-success';
                        statusIcon = 'bi-lightning-fill';
                      } else {
                        statusText = 'Đã kết thúc';
                        statusClass = 'bg-secondary';
                        statusIcon = 'bi-x-circle';
                      }
                    %>
                    <div class="d-flex align-items-center gap-3">
                      <span class="badge <%= statusClass %> fs-6 px-3 py-2">
                        <i class="bi <%= statusIcon %> me-2"></i><%= statusText %>
                      </span>
                      <% if (config.isActive) { %>
                        <span class="badge bg-success fs-6 px-3 py-2">
                          <i class="bi bi-check-circle me-2"></i>Đã kích hoạt
                        </span>
                      <% } else { %>
                        <span class="badge bg-danger fs-6 px-3 py-2">
                          <i class="bi bi-x-circle me-2"></i>Chưa kích hoạt
                        </span>
                      <% } %>
                    </div>
                    <div class="mt-3">
                      <small class="text-muted">
                        <i class="bi bi-calendar-event me-1"></i>
                        Bắt đầu: <strong><%= new Date(config.startDate).toLocaleString('vi-VN') %></strong>
                      </small>
                      <br>
                      <small class="text-muted">
                        <i class="bi bi-calendar-check me-1"></i>
                        Kết thúc: <strong><%= new Date(config.endDate).toLocaleString('vi-VN') %></strong>
                      </small>
                    </div>
                  </div>
                  <div class="col-md-4 text-end">
                    <% if (now < startDate) { %>
                      <div class="text-info">
                        <i class="bi bi-hourglass-split fs-1"></i>
                        <p class="mb-0 mt-2 fw-bold" id="countdown-display">Đang tải...</p>
                      </div>
                    <% } else if (now >= startDate && now <= endDate) { %>
                      <div class="text-success">
                        <i class="bi bi-lightning-fill fs-1"></i>
                        <p class="mb-0 mt-2 fw-bold" id="countdown-display">Đang tải...</p>
                      </div>
                    <% } else { %>
                      <div class="text-secondary">
                        <i class="bi bi-x-circle fs-1"></i>
                        <p class="mb-0 mt-2">Đã hết hạn</p>
                      </div>
                    <% } %>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- Statistics -->
        <div class="row mb-4">
          <div class="col-md-4">
            <div class="card text-white bg-warning">
              <div class="card-body">
                <h5 class="card-title">
                  <i class="bi bi-lightning-fill me-2"></i>Sản phẩm Flash Sale
                </h5>
                <h2 class="mb-0"><%= flashSaleProducts.length %></h2>
              </div>
            </div>
          </div>
          <div class="col-md-4">
            <div class="card text-white bg-success">
              <div class="card-body">
                <h5 class="card-title">
                  <i class="bi bi-check-circle me-2"></i>Đang hoạt động
                </h5>
                <h2 class="mb-0"><%= flashSaleProducts.filter(p => p.status === 'active').length %></h2>
              </div>
            </div>
          </div>
          <div class="col-md-4">
            <div class="card text-white bg-info">
              <div class="card-body">
                <h5 class="card-title">
                  <i class="bi bi-box-seam me-2"></i>Tổng sản phẩm
                </h5>
                <h2 class="mb-0"><%= allProducts.length %></h2>
              </div>
            </div>
          </div>
        </div>

        <!-- Flash Sale Products -->
        <div class="card mb-4">
          <div class="card-header">
            <h5 class="mb-0">Sản phẩm đang trong Flash Sale</h5>
          </div>
          <div class="card-body">
            <% if (flashSaleProducts.length === 0) { %>
              <p class="text-muted text-center py-4">Chưa có sản phẩm nào trong Flash Sale</p>
            <% } else { %>
              <div class="table-responsive">
                <table class="table table-hover">
                  <thead>
                    <tr>
                      <th>Hình ảnh</th>
                      <th>Tên sản phẩm</th>
                      <th>Giá gốc</th>
                      <th>Giảm giá</th>
                      <th>Giá sau giảm</th>
                      <th>Tồn kho</th>
                      <th>Trạng thái</th>
                      <th>Thao tác</th>
                    </tr>
                  </thead>
                  <tbody>
                    <% flashSaleProducts.forEach(product => { %>
                      <tr>
                        <td>
                          <img src="<%= product.thumbnail || '/images/no-image.png' %>" 
                               alt="<%= product.title %>" 
                               style="width: 50px; height: 50px; object-fit: cover; border-radius: 4px;">
                        </td>
                        <td><%= product.title %></td>
                        <td><%= product.price.toLocaleString('vi-VN') %>₫</td>
                        <td>
                          <span class="badge bg-danger"><%= product.discountPercentage %>%</span>
                        </td>
                        <td>
                          <strong class="text-danger">
                            <%= (product.price * (1 - product.discountPercentage/100)).toLocaleString('vi-VN') %>₫
                          </strong>
                        </td>
                        <td><%= product.stock %></td>
                        <td>
                          <% if (product.status === 'active') { %>
                            <span class="badge bg-success">Hoạt động</span>
                          <% } else { %>
                            <span class="badge bg-secondary">Không hoạt động</span>
                          <% } %>
                        </td>
                        <td>
                          <form action="/admin/flashsale/<%= product._id %>/remove" method="POST" class="d-inline">
                            <button type="submit" class="btn btn-sm btn-danger" 
                                    onclick="return confirm('Xóa khỏi Flash Sale?')">
                              <i class="bi bi-x-circle"></i> Xóa
                            </button>
                          </form>
                        </td>
                      </tr>
                    <% }) %>
                  </tbody>
                </table>
              </div>
            <% } %>
          </div>
        </div>

        <!-- Add Products to Flash Sale -->
        <div class="card">
          <div class="card-header">
            <h5 class="mb-0">Thêm sản phẩm vào Flash Sale</h5>
          </div>
          <div class="card-body">
            <form action="/admin/flashsale/add" method="POST">
              <div class="row">
                <div class="col-md-8">
                  <div class="mb-3">
                    <label class="form-label">Chọn sản phẩm</label>
                    <select name="productId" class="form-select" required>
                      <option value="">-- Chọn sản phẩm --</option>
                      <% allProducts.filter(p => !p.flashSale).forEach(product => { %>
                        <option value="<%= product._id %>">
                          <%= product.title %> - <%= product.price.toLocaleString('vi-VN') %>₫
                        </option>
                      <% }) %>
                    </select>
                  </div>
                </div>
                <div class="col-md-4">
                  <label class="form-label">&nbsp;</label>
                  <button type="submit" class="btn btn-warning w-100">
                    <i class="bi bi-plus-circle me-2"></i>Thêm vào Flash Sale
                  </button>
                </div>
              </div>
            </form>
          </div>
        </div>
      </main>
    </div>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
  
  <script>
    // Countdown timer for flash sale
    const startDate = new Date('<%= config.startDate %>').getTime();
    const endDate = new Date('<%= config.endDate %>').getTime();
    const now = new Date().getTime();
    
    const countdownElement = document.getElementById('countdown-display');
    
    if (countdownElement) {
      function updateCountdown() {
        const currentTime = new Date().getTime();
        
        // Sắp diễn ra - countdown đến khi bắt đầu
        if (currentTime < startDate) {
          const distance = startDate - currentTime;
          
          const days = Math.floor(distance / (1000 * 60 * 60 * 24));
          const hours = Math.floor((distance % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
          const minutes = Math.floor((distance % (1000 * 60 * 60)) / (1000 * 60));
          const seconds = Math.floor((distance % (1000 * 60)) / 1000);
          
          let countdownText = 'Bắt đầu sau: ';
          if (days > 0) {
            countdownText += `${days} ngày ${hours.toString().padStart(2, '0')}:${minutes.toString().padStart(2, '0')}:${seconds.toString().padStart(2, '0')}`;
          } else {
            countdownText += `${hours.toString().padStart(2, '0')}:${minutes.toString().padStart(2, '0')}:${seconds.toString().padStart(2, '0')}`;
          }
          
          countdownElement.textContent = countdownText;
        }
        // Đang diễn ra - countdown đến khi kết thúc
        else if (currentTime >= startDate && currentTime <= endDate) {
          const distance = endDate - currentTime;
          
          if (distance < 0) {
            countdownElement.textContent = 'Đã kết thúc';
            return;
          }
          
          const days = Math.floor(distance / (1000 * 60 * 60 * 24));
          const hours = Math.floor((distance % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
          const minutes = Math.floor((distance % (1000 * 60 * 60)) / (1000 * 60));
          const seconds = Math.floor((distance % (1000 * 60)) / 1000);
          
          let countdownText = 'Kết thúc sau: ';
          if (days > 0) {
            countdownText += `${days} ngày ${hours.toString().padStart(2, '0')}:${minutes.toString().padStart(2, '0')}:${seconds.toString().padStart(2, '0')}`;
          } else {
            countdownText += `${hours.toString().padStart(2, '0')}:${minutes.toString().padStart(2, '0')}:${seconds.toString().padStart(2, '0')}`;
          }
          
          countdownElement.textContent = countdownText;
        }
        // Đã kết thúc
        else {
          countdownElement.textContent = 'Đã kết thúc';
        }
      }
      
      updateCountdown();
      setInterval(updateCountdown, 1000);
    }
  </script>
</body>
</html>
