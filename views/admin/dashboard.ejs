<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> - Admin</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
</head>
<body>
  <%- include('partials/navbar') %>

  <div class="container-fluid">
    <div class="row">
      <%- include('partials/sidebar') %>

      <main class="col-md-10 ms-sm-auto px-md-4">
        <% if (success_msg && success_msg.length > 0) { %>
          <div class="alert alert-success alert-dismissible fade show mt-3" role="alert">
            <%= success_msg %>
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
          </div>
        <% } %>
        
        <% if (error_msg && error_msg.length > 0) { %>
          <div class="alert alert-danger alert-dismissible fade show mt-3" role="alert">
            <%= error_msg %>
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
          </div>
        <% } %>

        <div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-3 pb-2 mb-3 border-bottom">
          <h1 class="h2">Dashboard</h1>
        </div>

        <div class="row mb-4">
          <div class="col-md-3">
            <div class="card text-white admin-stat-card" style="background: var(--red-gradient);">
              <div class="card-body">
                <h5 class="card-title"><i class="bi bi-box-seam me-2"></i>Sản phẩm</h5>
                <h2><%= totalProducts %></h2>
              </div>
            </div>
          </div>
          <div class="col-md-3">
            <div class="card text-white admin-stat-card bg-success">
              <div class="card-body">
                <h5 class="card-title"><i class="bi bi-cart-check me-2"></i>Đơn hàng</h5>
                <h2><%= totalOrders %></h2>
              </div>
            </div>
          </div>
          <div class="col-md-3">
            <div class="card text-white admin-stat-card bg-info">
              <div class="card-body">
                <h5 class="card-title"><i class="bi bi-people me-2"></i>Người dùng</h5>
                <h2><%= totalUsers %></h2>
              </div>
            </div>
          </div>
          <div class="col-md-3">
            <div class="card text-white admin-stat-card bg-warning">
              <div class="card-body">
                <h5 class="card-title"><i class="bi bi-cash-stack me-2"></i>Doanh thu</h5>
                <h2><%= totalRevenue.toLocaleString('vi-VN') %>₫</h2>
              </div>
            </div>
          </div>
        </div>

        <h3>Đơn hàng gần đây</h3>
        <table class="table table-striped">
          <thead>
            <tr>
              <th>Mã đơn</th>
              <th>Khách hàng</th>
              <th>Tổng tiền</th>
              <th>Trạng thái</th>
              <th>Ngày đặt</th>
            </tr>
          </thead>
          <tbody>
            <% recentOrders.forEach(order => { %>
              <tr>
                <td>#<%= order._id.toString().slice(-6) %></td>
                <td><%= order.user.fullName %></td>
                <td><%= order.totalAmount.toLocaleString('vi-VN') %>₫</td>
                <td><span class="badge bg-info"><%= order.status %></span></td>
                <td><%= new Date(order.createdAt).toLocaleDateString('vi-VN') %></td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </main>
    </div>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
  <script src="https://cdn.tiny.cloud/1/no-api-key/tinymce/6/tinymce.min.js"></script>
  <script src="/js/admin.js"></script>
</body>
</html>
