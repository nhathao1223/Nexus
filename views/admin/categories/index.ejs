<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> - Admin</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
</head>
<body>
  <%- include('../partials/navbar') %>

  <div class="container-fluid">
    <div class="row">
      <%- include('../partials/sidebar') %>

      <main class="col-md-10 ms-sm-auto px-md-4">
        <% if (success_msg && success_msg.length > 0) { %>
          <div class="alert alert-success alert-dismissible fade show mt-3" role="alert">
            <%= success_msg %>
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
          </div>
        <% } %>
        
        <% if (error_msg && error_msg.length > 0) { %>
          <div class="alert alert-danger alert-dismissible fade show mt-3" role="alert">
            <%= error_msg %>
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
          </div>
        <% } %>

        <div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-3 pb-2 mb-3 border-bottom">
          <h1 class="h2">Quản lý danh mục</h1>
          <a href="/admin/categories/create" class="btn btn-primary">
            <i class="bi bi-plus"></i> Thêm danh mục
          </a>
        </div>

        <table class="table table-striped">
          <thead>
            <tr>
              <th>Tên danh mục</th>
              <th>Slug</th>
              <th>Trạng thái</th>
              <th>Ngày tạo</th>
              <th>Thao tác</th>
            </tr>
          </thead>
          <tbody>
            <% categories.forEach(category => { %>
              <tr>
                <td><%= category.name %></td>
                <td><%= category.slug %></td>
                <td>
                  <span class="badge <%= category.status === 'active' ? 'bg-success' : 'bg-secondary' %>">
                    <%= category.status === 'active' ? 'Hoạt động' : 'Không hoạt động' %>
                  </span>
                </td>
                <td><%= new Date(category.createdAt).toLocaleDateString('vi-VN') %></td>
                <td>
                  <a href="/admin/categories/<%= category._id %>/edit" class="btn btn-sm btn-warning">
                    <i class="bi bi-pencil"></i>
                  </a>
                  <form action="/admin/categories/<%= category._id %>?_method=DELETE" method="POST" class="d-inline" onsubmit="return confirm('Xác nhận xóa?')">
                    <button type="submit" class="btn btn-sm btn-danger">
                      <i class="bi bi-trash"></i>
                    </button>
                  </form>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </main>
    </div>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
  <script src="/js/admin.js"></script>
</body>
</html>
