<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> - Admin</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
</head>
<body>
  <%- include('../partials/navbar') %>

  <div class="container-fluid">
    <div class="row">
      <%- include('../partials/sidebar') %>

      <main class="col-md-10 ms-sm-auto px-md-4">
        <% if (success_msg && success_msg.length > 0) { %>
          <div class="alert alert-success alert-dismissible fade show mt-3" role="alert">
            <%= success_msg %>
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
          </div>
        <% } %>
        
        <% if (error_msg && error_msg.length > 0) { %>
          <div class="alert alert-danger alert-dismissible fade show mt-3" role="alert">
            <%= error_msg %>
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
          </div>
        <% } %>

        <div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-3 pb-2 mb-3 border-bottom">
          <h1 class="h2">Quản lý người dùng</h1>
        </div>

        <!-- Filter Form -->
        <div class="row mb-4">
          <div class="col-12">
            <form method="GET" class="row g-3">
              <div class="col-md-4">
                <input type="text" class="form-control" name="search" placeholder="Tìm theo tên hoặc email" value="<%= query.search || '' %>">
              </div>
              <div class="col-md-3">
                <select class="form-select" name="role">
                  <option value="">Tất cả vai trò</option>
                  <option value="user" <%= query.role === 'user' ? 'selected' : '' %>>Người dùng</option>
                  <option value="admin" <%= query.role === 'admin' ? 'selected' : '' %>>Quản trị viên</option>
                </select>
              </div>
              <div class="col-md-3">
                <select class="form-select" name="status">
                  <option value="">Tất cả trạng thái</option>
                  <option value="active" <%= query.status === 'active' ? 'selected' : '' %>>Hoạt động</option>
                  <option value="banned" <%= query.status === 'banned' ? 'selected' : '' %>>Bị khóa</option>
                </select>
              </div>
              <div class="col-md-2">
                <button type="submit" class="btn btn-primary">
                  <i class="bi bi-search"></i> Tìm kiếm
                </button>
              </div>
              <div class="col-md-2">
                <a href="/admin/users" class="btn btn-outline-secondary">
                  <i class="bi bi-arrow-clockwise"></i> Đặt lại
                </a>
              </div>
            </form>
          </div>
        </div>

        <!-- Users Table -->
        <div class="table-responsive">
          <table class="table table-striped">
            <thead>
              <tr>
                <th>Tên</th>
                <th>Email</th>
                <th>Vai trò</th>
                <th>Trạng thái</th>
                <th>Ngày tạo</th>
                <th>Thao tác</th>
              </tr>
            </thead>
            <tbody>
              <% if (users.length === 0) { %>
                <tr>
                  <td colspan="6" class="text-center">Không có người dùng nào</td>
                </tr>
              <% } else { %>
                <% users.forEach(user => { %>
                  <tr>
                    <td><%= user.fullName %></td>
                    <td><%= user.email %></td>
                    <td>
                      <% if (user.role === 'admin') { %>
                        <span class="badge bg-danger">Quản trị viên</span>
                      <% } else { %>
                        <span class="badge bg-primary">Người dùng</span>
                      <% } %>
                    </td>
                    <td>
                      <% if (user.isActive) { %>
                        <span class="badge bg-success">Hoạt động</span>
                      <% } else { %>
                        <span class="badge bg-secondary">Bị khóa</span>
                      <% } %>
                    </td>
                    <td><%= new Date(user.createdAt).toLocaleDateString('vi-VN') %></td>
                    <td>
                      <a href="/admin/users/<%= user._id %>" class="btn btn-sm btn-outline-primary">
                        <i class="bi bi-eye"></i> Xem
                      </a>
                      
                      <% if (user._id.toString() !== currentUser._id.toString()) { %>
                        <!-- Role Change Dropdown -->
                        <div class="dropdown d-inline-block ms-1">
                          <button class="btn btn-sm btn-outline-warning dropdown-toggle" type="button" data-bs-toggle="dropdown">
                            <i class="bi bi-person-gear"></i> Quyền
                          </button>
                          <ul class="dropdown-menu">
                            <li>
                              <button class="dropdown-item role-change-btn" 
                                      data-user-id="<%= user._id %>" 
                                      data-role="user"
                                      <%= user.role === 'user' ? 'disabled' : '' %>>
                                <i class="bi bi-person"></i> Người dùng
                              </button>
                            </li>
                            <li>
                              <button class="dropdown-item role-change-btn" 
                                      data-user-id="<%= user._id %>" 
                                      data-role="admin"
                                      <%= user.role === 'admin' ? 'disabled' : '' %>>
                                <i class="bi bi-person-badge"></i> Quản trị viên
                              </button>
                            </li>
                          </ul>
                        </div>

                        <!-- Status Toggle -->
                        <% if (user.isActive) { %>
                          <button class="btn btn-sm btn-outline-danger ms-1 status-toggle-btn" 
                                  data-user-id="<%= user._id %>" 
                                  data-action="ban">
                            <i class="bi bi-person-x"></i> Khóa
                          </button>
                        <% } else { %>
                          <button class="btn btn-sm btn-outline-success ms-1 status-toggle-btn" 
                                  data-user-id="<%= user._id %>" 
                                  data-action="unban">
                            <i class="bi bi-person-check"></i> Mở khóa
                          </button>
                        <% } %>
                      <% } else { %>
                        <span class="text-muted small">(Bạn)</span>
                      <% } %>
                    </td>
                  </tr>
                <% }) %>
              <% } %>
            </tbody>
          </table>
        </div>

        <!-- Pagination -->
        <% if (totalPages > 1) { %>
          <nav>
            <ul class="pagination justify-content-center">
              <% if (currentPage > 1) { %>
                <li class="page-item">
                  <a class="page-link" href="?page=<%= currentPage - 1 %>&<%= new URLSearchParams(query).toString() %>">Trước</a>
                </li>
              <% } %>
              
              <% for(let i = 1; i <= totalPages; i++) { %>
                <li class="page-item <%= currentPage === i ? 'active' : '' %>">
                  <a class="page-link" href="?page=<%= i %>&<%= new URLSearchParams(query).toString() %>"><%= i %></a>
                </li>
              <% } %>
              
              <% if (currentPage < totalPages) { %>
                <li class="page-item">
                  <a class="page-link" href="?page=<%= currentPage + 1 %>&<%= new URLSearchParams(query).toString() %>">Sau</a>
                </li>
              <% } %>
            </ul>
          </nav>
        <% } %>
      </main>
    </div>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
  <script>
    // Handle role change
    document.querySelectorAll('.role-change-btn').forEach(button => {
      button.addEventListener('click', async function() {
        const userId = this.getAttribute('data-user-id');
        const newRole = this.getAttribute('data-role');
        const roleName = newRole === 'admin' ? 'Quản trị viên' : 'Người dùng';
        
        if (!confirm(`Bạn có chắc muốn thay đổi quyền thành "${roleName}"?`)) {
          return;
        }
        
        try {
          const response = await fetch(`/admin/users/${userId}/role`, {
            method: 'PATCH',
            headers: {
              'Content-Type': 'application/json'
            },
            body: JSON.stringify({ role: newRole })
          });
          
          const result = await response.json();
          
          if (result.success) {
            alert('Cập nhật quyền thành công');
            location.reload();
          } else {
            alert(result.message || 'Có lỗi xảy ra');
          }
        } catch (error) {
          console.error('Error:', error);
          alert('Có lỗi xảy ra');
        }
      });
    });

    // Handle status toggle (ban/unban)
    document.querySelectorAll('.status-toggle-btn').forEach(button => {
      button.addEventListener('click', async function() {
        const userId = this.getAttribute('data-user-id');
        const action = this.getAttribute('data-action');
        const actionText = action === 'ban' ? 'khóa' : 'mở khóa';
        
        if (!confirm(`Bạn có chắc muốn ${actionText} người dùng này?`)) {
          return;
        }
        
        try {
          const response = await fetch(`/admin/users/${userId}/status`, {
            method: 'PATCH',
            headers: {
              'Content-Type': 'application/json'
            },
            body: JSON.stringify({ action })
          });
          
          const result = await response.json();
          
          if (result.success) {
            alert(`${actionText.charAt(0).toUpperCase() + actionText.slice(1)} người dùng thành công`);
            location.reload();
          } else {
            alert(result.message || 'Có lỗi xảy ra');
          }
        } catch (error) {
          console.error('Error:', error);
          alert('Có lỗi xảy ra');
        }
      });
    });
  </script>
</body>
</html>