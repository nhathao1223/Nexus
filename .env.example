# Server Configuration
PORT=3000
NODE_ENV=development

# Database - Replace with your actual MongoDB connection string
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/nexus?retryWrites=true&w=majority

# Session - Generate a strong random secret
SESSION_SECRET=your_super_secret_session_key_change_this

# Cloudinary (Optional - for image upload)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# MoMo Payment (UAT Environment)
MOMO_PARTNER_CODE=your_partner_code
MOMO_ACCESS_KEY=your_access_key
MOMO_SECRET_KEY=your_secret_key
MOMO_REDIRECT_URL=http://localhost:3000/payment/momo/return
MOMO_IPN_URL=http://localhost:3000/payment/momo/ipn

# Logging
LOG_LEVEL=debug