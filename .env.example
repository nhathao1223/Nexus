# Database
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/nexus

# Session
SESSION_SECRET=your-super-secret-session-key-here

# Server
PORT=3000
NODE_ENV=development

# MoMo Payment (Optional)
MOMO_PARTNER_CODE=your-momo-partner-code
MOMO_ACCESS_KEY=your-momo-access-key
MOMO_SECRET_KEY=your-momo-secret-key
MOMO_REDIRECT_URL=https://your-domain.vercel.app/payment/momo/return
MOMO_IPN_URL=https://your-domain.vercel.app/payment/momo/ipn

# Logging
LOG_LEVEL=info